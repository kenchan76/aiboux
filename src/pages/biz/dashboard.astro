---
import { bizDashboardRows } from "@/data/biz-content";
import BizDashboardLayout from "@/layouts/BizDashboardLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/starwind/table";

export const prerender = true;
---

<BizDashboardLayout title="履歴ダッシュボード | AIBOUX BIZ" canonicalPath="/biz/dashboard">
  <div class="grid min-h-[calc(100vh-3rem)] grid-cols-[220px_1fr]">
    <aside class="border-r border-neutral-200 bg-white p-4">
      <div class="mb-4 text-xs font-semibold tracking-widest text-violet-700">PLUS LITE</div>
      {["作成履歴", "ダウンロード履歴", "保存文書", "お気に入り", "フォルダ", "会社情報", "設定"].map((item, index) => (
        <a href="#" class={`mb-1 block rounded-md px-3 py-2 text-sm ${index === 0 ? "bg-neutral-100 font-semibold text-neutral-950" : "text-neutral-600 hover:bg-neutral-50"}`}>{item}</a>
      ))}
    </aside>
    <main class="p-6">
      <div class="mb-5 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold tracking-tight text-neutral-950">履歴ダッシュボード <Badge variant="outline" class="ml-2 border-violet-200 bg-violet-50 text-violet-700">Demo</Badge></h1>
          <p class="mt-1 text-sm text-neutral-600">作成、保存、再編集、再ダウンロードを管理する画面イメージです。</p>
        </div>
        <Button href="/biz/templates" variant="outline" class="border-violet-700 bg-violet-700 text-white hover:bg-violet-800 hover:text-white">テンプレートを探す</Button>
      </div>
      <div class="mb-4 grid gap-3 md:grid-cols-4">
        {["保存文書 24件", "今月の編集 38件", "再DL 11件", "期限確認 4件"].map((item) => (
          <Card size="sm" class="border-neutral-200 bg-white"><CardContent><div class="text-sm text-neutral-600">{item.split(" ")[0]}</div><div class="mt-1 text-2xl font-semibold text-neutral-950">{item.split(" ")[1]}</div></CardContent></Card>
        ))}
      </div>
      <Card size="sm" class="border-neutral-200 bg-white">
        <CardContent>
          <Table>
            <TableHeader><TableRow><TableHead>文書名</TableHead><TableHead>カテゴリ</TableHead><TableHead>最終更新日</TableHead><TableHead>形式</TableHead><TableHead>ステータス</TableHead><TableHead>操作</TableHead></TableRow></TableHeader>
            <TableBody>
              {bizDashboardRows.map((row) => (
                <TableRow><TableCell class="font-medium">{row.title}</TableCell><TableCell>{row.category}</TableCell><TableCell>{row.updatedAt}</TableCell><TableCell>{row.formats}</TableCell><TableCell><Badge variant="outline" class="border-violet-200 bg-violet-50 text-violet-700">{row.status}</Badge></TableCell><TableCell><a class="font-medium text-violet-700" href="/biz/editor">再編集</a></TableCell></TableRow>
              ))}
            </TableBody>
          </Table>
        </CardContent>
      </Card>
    </main>
  </div>
</BizDashboardLayout>
