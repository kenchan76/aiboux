---
import BizAdSlot from "@/components/biz/BizAdSlot.astro";
import TemplateGrid from "@/components/biz/TemplateGrid.astro";
import BizMarketingLayout from "@/layouts/BizMarketingLayout.astro";
import { bizTemplates } from "@/data/biz-content";

export const prerender = true;
---

<BizMarketingLayout title="テンプレート一覧 | AIBOUX BIZ" canonicalPath="/biz/templates">
  <TemplateGrid templates={bizTemplates} />
  <div class="mx-auto max-w-6xl px-4 pb-12 sm:px-5 lg:px-6">
    <BizAdSlot label="テンプレート一覧 広告枠" />
  </div>
</BizMarketingLayout>
