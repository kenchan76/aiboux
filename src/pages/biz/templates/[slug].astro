---
import BizAdSlot from "@/components/biz/BizAdSlot.astro";
import PopularTemplateCard from "@/components/biz/PopularTemplateCard.astro";
import BizMarketingLayout from "@/layouts/BizMarketingLayout.astro";
import { bizTemplates } from "@/data/biz-content";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";

export const prerender = true;

export function getStaticPaths() {
  return bizTemplates.map((template) => ({
    params: { slug: template.slug },
    props: { template },
  }));
}

const { template } = Astro.props;
const related = bizTemplates.filter((item) => item.slug !== template.slug && item.category === template.category).slice(0, 3);
---

<BizMarketingLayout title={`${template.title} | AIBOUX BIZ`} description={template.description} canonicalPath={`/biz/templates/${template.slug}`}>
  <section class="border-b border-neutral-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 py-10 sm:px-5 lg:grid-cols-[0.9fr_1.1fr] lg:px-6">
      <div>
        <div class="mb-3 text-sm text-neutral-500">テンプレート / {template.categoryLabel}</div>
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">{template.title}</h1>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{template.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {template.formats.map((format) => <Badge variant="outline" class="border-violet-200 bg-violet-50 text-violet-700">{format}</Badge>)}
          {template.tags.map((tag) => <Badge variant="outline" class="border-neutral-200 bg-neutral-50 text-neutral-600">{tag}</Badge>)}
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <Button href="/biz/editor" variant="outline" size="md" class="border-violet-700 bg-violet-700 text-white hover:bg-violet-800 hover:text-white">Webエディタで編集</Button>
          <Button variant="outline" size="md" data-biz-toast data-toast-title="ダウンロードデモ" data-toast-description="正式版でテンプレートファイルを出力します。">ダウンロード</Button>
        </div>
      </div>
      <Card size="sm" class="border-neutral-200 bg-white">
        <CardContent>
          <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-5">
            <div class="mx-auto max-w-sm border border-neutral-200 bg-white p-6 shadow-sm">
              <div class="mb-5 text-center text-lg font-semibold tracking-[0.24em]">{template.title.replace(/（.*?）/g, "")}</div>
              <div class="space-y-2 text-xs text-neutral-600">
                <div class="h-2 w-32 bg-neutral-200"></div>
                <div class="h-2 w-full bg-neutral-100"></div>
                <div class="h-2 w-11/12 bg-neutral-100"></div>
                <div class="mt-5 grid grid-cols-3 gap-2">
                  <span class="h-10 bg-neutral-100"></span><span class="h-10 bg-neutral-100"></span><span class="h-10 bg-neutral-100"></span>
                </div>
              </div>
            </div>
          </div>
          <h2 class="mt-4 text-sm font-semibold text-neutral-950">編集できる項目</h2>
          <div class="mt-2 flex flex-wrap gap-2">
            {template.editableFields.map((field) => <span class="rounded-md border border-neutral-200 px-2 py-1 text-xs text-neutral-600">{field}</span>)}
          </div>
        </CardContent>
      </Card>
    </div>
  </section>
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-5 lg:px-6">
      <BizAdSlot label="テンプレート詳細下 広告枠" />
      {related.length > 0 && (
        <div class="mt-8">
          <h2 class="mb-4 text-2xl font-semibold tracking-tight text-neutral-950">関連テンプレート</h2>
          <div class="grid gap-4 md:grid-cols-3">
            {related.map((item) => <PopularTemplateCard template={item} />)}
          </div>
        </div>
      )}
    </div>
  </section>
</BizMarketingLayout>
