---
import BizFaqAccordion from "@/components/biz/BizFaqAccordion.astro";
import BizMarketingLayout from "@/layouts/BizMarketingLayout.astro";
import { bizFaqs } from "@/data/biz-content";

export const prerender = true;
---

<BizMarketingLayout title="ヘルプ | AIBOUX BIZ" canonicalPath="/biz/help">
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-5 lg:px-6">
    <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">ヘルプセンター</h1>
    <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600">テンプレートの探し方、編集、ダウンロード、Plus Liteについて確認できます。</p>
    <div id="faq" class="mt-6"><BizFaqAccordion faqs={bizFaqs} /></div>
  </section>
</BizMarketingLayout>
