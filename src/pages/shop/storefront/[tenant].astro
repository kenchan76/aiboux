---
import ShopSeoHead from "@/components/shop/ShopSeoHead.astro";
import { ShadcnStorefront } from "@/components/shop/storefront/ShadcnStorefront";
import {
  buildShopBreadcrumbJsonLd,
  buildShopItemListJsonLd,
  buildShopOrganizationJsonLd,
  buildShopRobotsContent,
  buildShopSiteNavigationJsonLd,
  buildShopSocialMeta,
  buildShopStructuredDataGraph,
  buildShopStorefrontSeoMeta,
  buildShopWebPageJsonLd,
  buildShopWebsiteJsonLd,
} from "@/lib/shopSeo";
import { getShopStorefrontLayout, getShopStorefrontProfile, listShopStorefrontProducts } from "@/lib/server/shopStorefront";
import {
  buildShopBreadcrumbSupportLinks,
  buildShopContextualLinkSections,
  buildShopFooterColumns,
  buildShopFooterSeoSitemapLinks,
  buildShopHeaderCategoryLinks,
  buildShopPageActionMap,
  buildShopPageBuyingGuide,
  buildShopPageQualitySummary,
  buildShopTrustMatrix,
} from "@/lib/shopStorefrontShared";
import "@/styles/global.css";

export const prerender = false;

const tenantParam = String(Astro.params.tenant ?? "").trim();
const isKnownTenant = tenantParam === "aiboux";
const profile = isKnownTenant ? await getShopStorefrontProfile(tenantParam) : null;
const products = profile ? await listShopStorefrontProducts(profile.tenantId) : [];
const layout = profile ? await getShopStorefrontLayout(profile.tenantId) : null;

if (!isKnownTenant || !profile) {
  Astro.response.status = 404;
}

Astro.response.headers.set("Cache-Control", isKnownTenant && profile ? "public, max-age=30, s-maxage=60, stale-while-revalidate=30" : "no-store");

const storeName = profile?.storeName ?? "AIBOUX Store";
const meta = buildShopStorefrontSeoMeta({
  page: "",
  storeName,
  found: isKnownTenant && Boolean(profile),
});
const title = meta.title;
const canonicalUrl = isKnownTenant && profile
  ? new URL(`/s/${encodeURIComponent(tenantParam)}/`, "https://shop.aiboux.com").toString()
  : Astro.url.toString();
const tenantRoot = `/s/${encodeURIComponent(tenantParam)}`;
const socialMeta = buildShopSocialMeta({
  title,
  description: meta.description,
  canonicalUrl,
  imageUrl: products[0]?.imageUrl,
  storeName,
});
const publicProductCards = products.map((product) => ({
  id: product.id,
  displayName: product.displayName,
}));
const breadcrumbItems = [{ name: "TOP", href: "", url: canonicalUrl }];
const footerColumns = buildShopFooterColumns(tenantRoot);
const footerSeoSitemapLinks = buildShopFooterSeoSitemapLinks(tenantRoot);
const headerCategoryLinks = buildShopHeaderCategoryLinks(tenantRoot);
const contextualLinkSections = buildShopContextualLinkSections("", tenantRoot);
const contextualLinks = contextualLinkSections.flatMap((section) => section.links);
const breadcrumbSupportLinks = buildShopBreadcrumbSupportLinks("", tenantRoot);
const actionMap = buildShopPageActionMap("", tenantRoot);
const actionMapLinks = actionMap.steps.map((step) => ({ label: step.label, href: step.href }));
const buyingGuideLinks = buildShopPageBuyingGuide("", tenantRoot).map((item) => ({ label: item.label, href: item.href }));
const pageQualityLinks = buildShopPageQualitySummary("", tenantRoot).signals.map((item) => ({ label: item.label, href: item.href }));
const trustMatrixLinks = buildShopTrustMatrix("", tenantRoot, { subscriptionSchemaPending: true }).signals.map((item) => ({ label: item.label, href: item.href }));
const structuredData = JSON.stringify(buildShopStructuredDataGraph([
  buildShopBreadcrumbJsonLd(breadcrumbItems),
  buildShopWebsiteJsonLd({ storeName, absoluteTenantRoot: canonicalUrl }),
  buildShopOrganizationJsonLd({
    storeName,
    absoluteTenantRoot: canonicalUrl,
    tenantRoot,
    contactEmail: profile?.contactEmail,
    phone: profile?.phone,
  }),
  buildShopItemListJsonLd({
    page: "",
    canonicalUrl,
    tenantRoot,
    publicProductCards,
    categoryCards: [],
    accountCards: [],
    policySupportCards: [],
    contextualLinks,
  }),
  buildShopWebPageJsonLd({
    page: "",
    name: title,
    description: meta.description,
    canonicalUrl,
    absoluteTenantRoot: canonicalUrl,
    breadcrumbItems,
  }),
  buildShopSiteNavigationJsonLd({
    canonicalUrl,
    storeName,
    links: [
      ...headerCategoryLinks,
      ...breadcrumbSupportLinks,
      ...pageQualityLinks,
      ...actionMapLinks,
      ...trustMatrixLinks,
      ...buyingGuideLinks,
      ...contextualLinks,
      ...footerColumns.flatMap((column) => column.links),
      ...footerSeoSitemapLinks,
    ],
  }),
].filter(Boolean)));

const storefrontProducts = products.map((product) => ({
  id: product.id,
  image: product.imageUrl,
  name: product.displayName,
  price: product.salePrice.toLocaleString("ja-JP"),
  category: product.categoryName,
  inStock: product.inStock,
  href: `/s/${encodeURIComponent(tenantParam)}/product/${product.id}`,
}));
---

<!doctype html>
<html lang="ja" class="bg-white">
  <head>
    <ShopSeoHead
      title={title}
      description={socialMeta.description}
      robots={buildShopRobotsContent("")}
      canonicalUrl={canonicalUrl}
      socialMeta={socialMeta}
      structuredData={structuredData}
    />
  </head>
  <body>
    {
      isKnownTenant && profile ? (
        <ShadcnStorefront storeName={storeName} products={storefrontProducts} layout={layout!} contextualLinkSections={contextualLinkSections} />
      ) : (
        <main class="mx-auto flex min-h-screen max-w-xl flex-col justify-center px-4 py-8">
          <p class="text-sm font-bold text-neutral-500">404</p>
          <h1 class="mt-2 text-xl font-bold text-neutral-950">ストアが見つかりません</h1>
          <p class="mt-2 text-sm leading-6 text-neutral-600">公開中のストアだけを表示できます。</p>
        </main>
      )
    }
  </body>
</html>
