    { id: "setsuka-storage", displayName: "キッチン保存容器 6点セット", categoryName: "キッチン用品", salePrice: 3280, imageUrl: imageForSalesProduct("キッチン保存容器 6点セット", "キッチン用品", 2) },
    { id: "setsuka-cleaning", displayName: "毎日使えるホームケア洗剤セット", categoryName: "日用品", salePrice: 1680, imageUrl: imageForSalesProduct("毎日使えるホームケア洗剤セット", "日用品", 2) },
    { id: "setsuka-skincare", displayName: "ナチュラルスキンケア 3点セット", categoryName: "ビューティー", salePrice: 4280, imageUrl: imageForSalesProduct("ナチュラルスキンケア 3点セット", "ビューティー", 2) },
    { id: "setsuka-snack", displayName: "焼き菓子アソートボックス", categoryName: "食品・飲料", salePrice: 2380, imageUrl: imageForSalesProduct("焼き菓子アソートボックス", "食品・飲料", 2) },
    { id: "setsuka-pet", displayName: "ペットケアおでかけセット", categoryName: "ペット用品", salePrice: 3480, imageUrl: imageForSalesProduct("ペットケアおでかけセット", "ペット用品", 2) },
    { id: "setsuka-tea", displayName: "国産茶葉ティーバッグ 30包", categoryName: "コーヒー・お茶", salePrice: 1780, imageUrl: imageForSalesProduct("国産茶葉ティーバッグ 30包", "コーヒー・お茶", 2) },
    { id: "setsuka-rice", displayName: "北海道ゆめぴりか 2kg", categoryName: "食品・飲料", salePrice: 2680, imageUrl: imageForSalesProduct("北海道ゆめぴりか 2kg", "食品・飲料", 3) },
    { id: "setsuka-pan", displayName: "ふっくら食パン詰め合わせ", categoryName: "食品・飲料", salePrice: 2280, imageUrl: imageForSalesProduct("ふっくら食パン詰め合わせ", "食品・飲料", 4) },
