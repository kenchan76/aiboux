                : /美容|コスメ|スキン|beauty|skin/.test(source)
                  ? "beauty"
	                : /ギフト|gift/.test(source)
	                  ? "gift"
	                  : /文具|本|stationery|book/.test(source)
	                    ? "stationery"
	                    : "daily";
  const variants = groups[key];
  return `${variants[index % variants.length]}&sig=${encodeURIComponent(`${key}-${index}-${name}`)}`;
}

function toSalesProductDetail(productValue: any, index: number) {
  const category = inferSalesCategory(String(productValue?.displayName ?? ""), String(productValue?.categoryName ?? ""));
  const name = displayNameForPublicProduct(productValue, category);
  const imageUrl = imageForSalesProduct(name, category, index);
  const description = isPublicTestProductName(productValue?.displayName) || !productValue?.description
    ? `${name}は、毎日の暮らしで使いやすい品質と価格のバランスを重視した雪花セレクトの商品です。ギフトやまとめ買いにも選びやすいよう、配送条件と在庫状況を確認しながら購入できます。`
    : String(productValue.description);
  return {
    ...productValue,
    displayName: name,
    categoryName: category,
    imageUrl,
    imageAlt: `${name} 商品画像`,
    description,
  };
}

function buildProductThumbnails(productValue: any): Array<{ imageUrl: string; alt: string }> {
  const category = String(productValue?.categoryName ?? "日用品");
  const name = String(productValue?.displayName ?? "商品");
  const galleryImages = buildProductGalleryImages(name, category, productValue.imageUrl);
  return Array.from({ length: Math.max(productDesign?.gallery.thumbnailCount ?? 5, 5) }).map((_, index) => ({
    imageUrl: galleryImages[index % galleryImages.length],
    alt: `${name} サムネイル ${index + 1}`,
  }));
}

