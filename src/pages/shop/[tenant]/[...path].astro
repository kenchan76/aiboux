---
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";
import {
  buildReturnsText,
  buildShippingText,
  formatShopPrice,
  getShopStorefrontLayout,
  getShopStorefrontProduct,
  getShopStorefrontProfile,
  listShopStorefrontCategories,
  listShopStorefrontProducts,
} from "@/lib/server/shopStorefront";
import "@/styles/global.css";

export const prerender = false;

const tenantParam = String(Astro.params.tenant ?? "").trim();
const pathParam = String(Astro.params.path ?? "").replace(/^\/+|\/+$/g, "");
const isKnownTenant = tenantParam === "aiboux";
const profile = isKnownTenant ? await getShopStorefrontProfile(tenantParam) : null;

const allowedPaths = new Set([
  "products",
  "categories",
  "cart",
  "checkout",
  "contact",
  "legal",
  "privacy",
  "shipping",
  "returns",
  "faq",
]);

const productMatch = pathParam.match(/^product\/([^/]+)$/);
const isAllowedPath = Boolean(profile) && (allowedPaths.has(pathParam) || Boolean(productMatch));

if (!isKnownTenant || !isAllowedPath) {
  Astro.response.status = 404;
}

Astro.response.headers.set("Cache-Control", isKnownTenant && isAllowedPath ? "public, max-age=30, s-maxage=60, stale-while-revalidate=30" : "no-store");

const tenantRoot = `/s/${encodeURIComponent(tenantParam)}`;
const page = productMatch ? "product" : pathParam;
const productId = productMatch?.[1] ?? "";
const products = profile ? await listShopStorefrontProducts(profile.tenantId) : [];
const categories = profile ? await listShopStorefrontCategories(profile.tenantId) : [];
const product = profile && productId ? await getShopStorefrontProduct(profile.tenantId, productId) : null;
const layout = profile ? await getShopStorefrontLayout(profile.tenantId) : null;
const storeName = profile?.storeName ?? "AIBOUX Store";
const headerDesign = layout?.global.header;
const logo = layout?.global.logo;
const productDesign = layout?.pages.productDetail;
const logoHref = logo?.linkType === "custom" && logo.customUrl ? logo.customUrl : `${tenantRoot}/`;
const activeSubscriptionPlans = product?.subscriptionPlans ?? [];
const primarySubscriptionPlan = activeSubscriptionPlans[0] ?? null;
const subscriptionSchemaPending = Boolean(product?.subscriptionSchemaPending);
const salesProduct = product ? toSalesProductDetail(product, 0) : null;
const salesProductThumbnails = salesProduct ? buildProductThumbnails(salesProduct) : [];
const relatedProductCards = salesProduct
  ? buildRelatedSalesProducts(products, salesProduct).slice(0, 4)
  : [];

const pageMeta: Record<string, { title: string; description: string }> = {
  products: { title: "商品一覧", description: "公開中の商品を表示します。" },
  categories: { title: "カテゴリ", description: "公開中カテゴリを表示します。" },
  cart: { title: "カート", description: "カート内の商品を確認します。" },
  checkout: { title: "チェックアウト", description: "注文内容と配送先を確認します。" },
  contact: { title: "問い合わせ", description: "ストアへの問い合わせを受け付けます。" },
  legal: { title: "特定商取引法に基づく表示", description: "販売者情報と取引条件を表示します。" },
  privacy: { title: "プライバシーポリシー", description: "個人情報の取り扱いを表示します。" },
  shipping: { title: "配送について", description: "配送方法と送料の情報を表示します。" },
  returns: { title: "返品について", description: "返品・交換条件を表示します。" },
  faq: { title: "よくある質問", description: "ストア利用前によく確認される項目を表示します。" },
  product: { title: salesProduct?.displayName || "商品詳細", description: salesProduct ? `${salesProduct.displayName} の商品詳細です。` : "商品が見つかりません。" },
};

const meta = pageMeta[page] ?? { title: "ストアページ", description: "AIBOUX Storeの公開ページです。" };
const title = isKnownTenant && isAllowedPath ? `${meta.title} | AIBOUX Store` : "ページが見つかりません | AIBOUX Store";
const canonicalUrl = isKnownTenant && isAllowedPath
  ? new URL(`${tenantRoot}/${pathParam}`, "https://shop.aiboux.com").toString()
  : Astro.url.toString();

const policyText = profile && ["legal", "privacy", "shipping", "returns"].includes(page)
  ? page === "legal"
    ? profile.tokushohoText
    : page === "privacy"
      ? profile.privacyPolicyText
      : page === "shipping"
        ? buildShippingText(profile)
        : buildReturnsText(profile)
  : "";
const policyBlocks = policyText ? splitPolicyText(policyText) : [];

function subscriptionIntervalLabel(unit: "day" | "week" | "month", count: number): string {
  const safeCount = Math.max(Math.trunc(Number(count) || 1), 1);
  if (unit === "week") return safeCount === 1 ? "毎週" : `${safeCount}週間ごと`;
  if (unit === "day") return `${safeCount}日ごと`;
  return safeCount === 1 ? "毎月" : `${safeCount}か月ごと`;
}

function isPublicTestProductName(value: string | null | undefined): boolean {
  return /公開検証商品|検証商品|テスト商品|dummy|sample|test product/i.test(String(value ?? ""));
}

function isWeakStoreImage(value: string | null | undefined): boolean {
  if (!value) return true;
  return /placeholder|skeleton|gray|grey|画像なし|no-image|\/shop\/design\/hero-|unsplash\.com\/photo-1516321318423/i.test(value);
}

function inferSalesCategory(name: string, category: string): string {
  const source = `${name} ${category}`.toLowerCase();
  if (/コーヒー|珈琲|茶|coffee|tea/.test(source)) return "コーヒー・お茶";
  if (/タオル|寝具|布|towel/.test(source)) return "タオル・寝具";
  if (/ボトル|水筒|保存|キッチン|kitchen|bottle|家電/.test(source)) return "キッチン用品";
  if (/食品|飲料|菓子|パン|food|drink|snack/.test(source)) return "食品・飲料";
  if (/洗剤|掃除|日用品|ホームケア|daily|clean/.test(source)) return "日用品";
  if (/美容|コスメ|ケア|beauty|skin/.test(source)) return "ビューティー";
  if (/ペット|pet/.test(source)) return "ペット用品";
  if (/ギフト|gift/.test(source)) return "ギフト";
  return category && category !== "未分類" && !/^\d+$/.test(category) ? category : "日用品";
}

function displayNameForPublicProduct(productValue: any, category: string): string {
  const rawName = String(productValue?.displayName ?? "");
  if (!isPublicTestProductName(rawName)) return rawName || "雪花セレクト 日用品セット";
  if (category === "タオル・寝具") return "雪花セレクト ギフトタオル 2枚セット";
  if (category === "コーヒー・お茶") return "雪花セレクト ドリップコーヒー 20袋";
  if (category === "キッチン用品") return "軽量ステンレスボトル 500ml";
  if (category === "食品・飲料") return "焼き菓子アソートボックス";
  if (category === "ビューティー") return "ナチュラルスキンケア 3点セット";
  return "毎日使えるホームケア洗剤セット";
}

function imageForSalesProduct(name: string, category: string, index: number): string {
  const source = `${name} ${category}`.toLowerCase();
  const groups: Record<string, string[]> = {
    coffee: [
      "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1544787219-7f47ccb76574?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    bottle: [
      "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1523362628745-0c100150b504?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1622483767028-3f66f32aef97?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    towel: [
      "https://images.unsplash.com/photo-1583847268964-b28dc8f51f92?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1631889993959-41b4e9c6e3c5?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    food: [
      "https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1513885535751-8b9238bd345a?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    kitchen: [
      "https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1586201375761-83865001e31c?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    daily: [
      "https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    beauty: [
      "https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1556228720-195a672e8a03?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1596462502278-27bfdc403348?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    pet: [
      "https://images.unsplash.com/photo-1601758228041-f3b2795255f1?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1548199973-03cce0bbc87b?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    gift: [
      "https://images.unsplash.com/photo-1513885535751-8b9238bd345a?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1513201099705-a9746e1e201f?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1607344645866-009c320f6103?auto=format&fit=crop&w=920&h=920&q=84",
    ],
  };
  const key = /コーヒー|茶|coffee|tea/.test(source)
    ? "coffee"
    : /ボトル|水筒|bottle/.test(source)
      ? "bottle"
      : /タオル|寝具|towel/.test(source)
        ? "towel"
        : /食品|飲料|菓子|パン|food|drink|snack/.test(source)
          ? "food"
          : /キッチン|保存|家電|kitchen/.test(source)
            ? "kitchen"
            : /美容|コスメ|ケア|beauty|skin/.test(source)
              ? "beauty"
              : /ペット|pet/.test(source)
                ? "pet"
                : /ギフト|gift/.test(source)
                  ? "gift"
                  : "daily";
  const variants = groups[key];
  return `${variants[index % variants.length]}&sig=${encodeURIComponent(`${key}-${index}-${name}`)}`;
}

function toSalesProductDetail(productValue: any, index: number) {
  const category = inferSalesCategory(String(productValue?.displayName ?? ""), String(productValue?.categoryName ?? ""));
  const name = displayNameForPublicProduct(productValue, category);
  const imageUrl = isWeakStoreImage(productValue?.imageUrl) || isPublicTestProductName(productValue?.displayName)
    ? imageForSalesProduct(name, category, index)
    : String(productValue.imageUrl);
  const description = isPublicTestProductName(productValue?.displayName) || !productValue?.description
    ? `${name}は、毎日の暮らしで使いやすい品質と価格のバランスを重視した雪花セレクトの商品です。ギフトやまとめ買いにも選びやすいよう、配送条件と在庫状況を確認しながら購入できます。`
    : String(productValue.description);
  return {
    ...productValue,
    displayName: name,
    categoryName: category,
    imageUrl,
    imageAlt: `${name} 商品画像`,
    description,
  };
}

function buildProductThumbnails(productValue: any): Array<{ imageUrl: string; alt: string }> {
  const category = String(productValue?.categoryName ?? "日用品");
  const name = String(productValue?.displayName ?? "商品");
  return Array.from({ length: Math.max(productDesign?.gallery.thumbnailCount ?? 5, 5) }).map((_, index) => ({
    imageUrl: index === 0 ? productValue.imageUrl : imageForSalesProduct(name, category, index),
    alt: `${name} サムネイル ${index + 1}`,
  }));
}

function buildRelatedSalesProducts(sourceProducts: any[], currentProduct: any) {
  const normalized = sourceProducts
    .filter((item) => item.id !== currentProduct.id)
    .map((item, index) => toSalesProductDetail(item, index + 1))
    .filter((item, index, array) => array.findIndex((next) => next.displayName === item.displayName) === index);
  const fallback = [
    { id: "setsuka-coffee-related", displayName: "雪花セレクト ドリップコーヒー 20袋", categoryName: "コーヒー・お茶", salePrice: 1980, imageUrl: imageForSalesProduct("雪花セレクト ドリップコーヒー 20袋", "コーヒー・お茶", 1) },
    { id: "setsuka-bottle-related", displayName: "軽量ステンレスボトル 500ml", categoryName: "キッチン用品", salePrice: 2480, imageUrl: imageForSalesProduct("軽量ステンレスボトル 500ml", "キッチン用品", 1) },
    { id: "setsuka-towel-related", displayName: "雪花セレクト ギフトタオル 2枚セット", categoryName: "タオル・寝具", salePrice: 2980, imageUrl: imageForSalesProduct("雪花セレクト ギフトタオル 2枚セット", "タオル・寝具", 1) },
    { id: "setsuka-gift-related", displayName: "季節のギフトボックス", categoryName: "ギフト", salePrice: 5980, imageUrl: imageForSalesProduct("季節のギフトボックス", "ギフト", 1) },
  ];
  return [...normalized, ...fallback].filter((item, index, array) => item.id !== currentProduct.id && array.findIndex((next) => next.displayName === item.displayName) === index);
}

function splitPolicyText(value: string): Array<{ title: string; body: string }> {
  const lines = value.split(/\n+/).map((line) => line.trim()).filter(Boolean);
  if (!lines.length) return [];
  const blocks: Array<{ title: string; body: string }> = [];
  let current: { title: string; body: string } | null = null;
  for (const line of lines) {
    const colonMatch = line.match(/^([^:：]{2,28})[:：]\s*(.+)$/);
    if (colonMatch) {
      current = { title: colonMatch[1], body: colonMatch[2] };
      blocks.push(current);
    } else if (current) {
      current.body += `\n${line}`;
    } else {
      blocks.push({ title: "概要", body: line });
    }
  }
  return blocks;
}
---

<!doctype html>
<html lang="ja" class="bg-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <NotoSansJpHead />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={canonicalUrl} />
  </head>
  <body class="min-h-screen bg-white text-neutral-950">
    <header class="border-b border-neutral-900 bg-[#0f1722] text-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2 text-xs">
        <span>{headerDesign?.deliveryText ?? "お届け先: 東京都 千代田区"}</span>
        <span>{headerDesign?.shippingText ?? "送料無料は ¥2,000"}</span>
        <span class="flex gap-5"><span>{headerDesign?.helpText ?? "ヘルプ・サポート"}</span><span>{headerDesign?.noticeText ?? "お知らせ"}</span></span>
      </div>
      <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-3">
        <a href={logoHref} class="shrink-0 text-xl font-bold tracking-tight">
          {
            logo && logo.displayMode !== "storeNameOnly" && logo.imageUrl ? (
              <span class="inline-flex items-center gap-2">
                <img src={logo.imageUrl} alt={logo.alt} style={`width:${logo.desktopWidth}px`} class="max-h-10 object-contain" />
                {logo.displayMode === "imageWithStoreName" ? <span>{storeName}</span> : null}
              </span>
            ) : storeName
          }
        </a>
        <div class="flex h-10 min-w-0 flex-1 overflow-hidden rounded bg-white text-neutral-900">
          <span class="hidden items-center border-r border-neutral-200 bg-neutral-100 px-3 text-xs md:flex">すべてのカテゴリ</span>
          <input class="h-10 min-w-0 flex-1 border-0 px-4 text-sm outline-none" placeholder={headerDesign?.searchPlaceholder ?? "キーワード・商品名・ブランド名で検索"} />
          <span class="flex w-12 items-center justify-center bg-amber-500 text-neutral-950">検索</span>
        </div>
        <a class="hidden text-xs md:block" href={`${tenantRoot}/contact`}>アカウント<br /><b>ログイン</b></a>
        <a class="hidden text-xs md:block" href={`${tenantRoot}/checkout`}>注文履歴</a>
        <a class="text-xs" href={`${tenantRoot}/cart`}>カート</a>
      </div>
      <nav class="mx-auto flex max-w-6xl gap-5 overflow-x-auto border-t border-white/10 px-4 py-2 text-xs">
        <a class="shrink-0 font-bold" href={`${tenantRoot}/categories`}>すべてのカテゴリー</a>
        {(layout?.global.navigation.items ?? []).map((item) => <a class={item === "セール" ? "shrink-0 font-bold text-red-400" : "shrink-0"} href={`${tenantRoot}/products`}>{item}</a>)}
      </nav>
    </header>
    {
      isKnownTenant && isAllowedPath ? (
        <main class="mx-auto max-w-screen-xl px-4 py-8">
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">{storeName}</p>
            <h1 class="mt-2 text-2xl font-bold tracking-tight text-neutral-950">{meta.title}</h1>
            <p class="mt-2 text-sm leading-6 text-neutral-600">{meta.description}</p>
          </div>

          {page === "products" ? (
            <section class="grid gap-4 md:grid-cols-3 lg:grid-cols-4">
              {products.length === 0 ? (
                <div class="col-span-full rounded-lg border border-dashed border-neutral-200 bg-neutral-50 px-4 py-12 text-center text-sm text-neutral-600">
                  公開商品はまだありません。管理画面で商品を公開すると、この一覧に表示されます。
                </div>
              ) : products.map((item) => (
                <article class="rounded-lg border border-neutral-200 bg-white p-4">
                  <div class="flex aspect-square items-center justify-center rounded-md bg-neutral-50">
                    {item.imageUrl ? <img src={item.imageUrl} alt={item.imageAlt} class="h-full w-full object-contain p-3" /> : <span class="text-xs text-neutral-500">画像未登録</span>}
                  </div>
                  <h2 class="mt-3 text-sm font-semibold text-neutral-950"><a href={`${tenantRoot}/product/${item.id}`}>{item.displayName}</a></h2>
                  <p class="mt-1 text-sm font-bold text-red-700">{formatShopPrice(item.salePrice)}</p>
                  <button
                    class="mt-3 h-9 rounded-md border border-neutral-300 bg-white px-3 text-xs font-semibold hover:bg-neutral-50"
                    type="button"
                    data-cart-add
                    data-product-id={item.id}
                    data-product-name={item.displayName}
                    data-product-price={String(item.salePrice)}
                    data-product-image={item.imageUrl}
                  >
                    カートに追加
                  </button>
                </article>
              ))}
            </section>
          ) : null}

          {page === "product" ? (
            product && salesProduct ? (
              <section class="grid gap-6 lg:grid-cols-[360px_minmax(0,1fr)_300px]" data-testid="public-product-detail">
                <div class={productDesign?.gallery.position === "top" ? "lg:col-span-3" : ""} data-testid="public-product-gallery">
                  <div class={productDesign?.gallery.position === "top" ? "grid gap-3" : "flex gap-3"}>
                    <div class={productDesign?.gallery.position === "top" ? "order-2 flex gap-2" : "grid h-fit gap-2"}>
                      {salesProductThumbnails.map((thumb) => (
                        <button class="flex size-14 items-center justify-center overflow-hidden rounded-md border border-neutral-200 bg-white p-0.5 hover:border-amber-400" type="button" data-testid="product-thumbnail">
                          <img src={thumb.imageUrl} alt={thumb.alt} class="h-full w-full rounded object-cover" loading="lazy" />
                        </button>
                      ))}
                    </div>
                    <div class="flex aspect-square flex-1 items-center justify-center overflow-hidden rounded-lg border border-neutral-200 bg-white">
                      <img src={salesProduct.imageUrl} alt={salesProduct.imageAlt} class="h-full w-full object-cover" data-testid="product-main-image" />
                    </div>
                  </div>
                </div>
                <div data-testid="public-product-info">
                  {productDesign?.content.showBrand ? <p class="text-sm text-blue-700">{salesProduct.categoryName || "AIBOUX ブランド"}</p> : null}
                  <h1 class="mt-2 text-2xl font-bold leading-tight text-neutral-950">{salesProduct.displayName}</h1>
                  {productDesign?.content.showReviews ? <p class="mt-3 border-b border-neutral-200 pb-3 text-sm text-amber-500">★★★★★ <a class="text-blue-700" href="#reviews">(レビューを確認)</a></p> : null}
                  <div class="mt-4 text-3xl font-bold text-red-700">{formatShopPrice(salesProduct.salePrice)} <span class="text-sm font-normal text-neutral-500">税込</span></div>
                  {productDesign?.content.showPoints ? <p class="mt-2 text-sm text-neutral-600">ポイント付与対象商品です。</p> : null}
                  {productDesign?.content.showVariations ? (
                    <div class="mt-5">
                      <h2 class="text-sm font-bold text-neutral-950">バリエーション</h2>
                      <div class="mt-2 flex flex-wrap gap-2">
                        <span class="rounded-md border border-neutral-200 px-3 py-2 text-xs">標準</span>
                        <span class="rounded-md border border-neutral-200 px-3 py-2 text-xs">ギフト対応</span>
                      </div>
                    </div>
                  ) : null}
                  <section class="mt-6 rounded-lg border border-neutral-200 bg-white p-4">
