    { id: "setsuka-laundry", displayName: "部屋干しランドリー洗剤セット", categoryName: "日用品", salePrice: 1880, imageUrl: imageForSalesProduct("部屋干しランドリー洗剤セット", "日用品", 3) },
    { id: "setsuka-candle", displayName: "リラックスアロマキャンドル", categoryName: "ギフト", salePrice: 1980, imageUrl: imageForSalesProduct("リラックスアロマキャンドル", "ギフト", 3) },
    { id: "setsuka-stationery", displayName: "毎日使える文具スターターセット", categoryName: "本・文具", salePrice: 1680, imageUrl: imageForSalesProduct("毎日使える文具スターターセット", "本・文具", 3) },
  ];
  return [...fallback, ...normalized].filter((item, index, array) => item.id !== currentId && array.findIndex((next) => next.displayName === item.displayName) === index);
}

function splitPolicyText(value: string): Array<{ title: string; body: string }> {
  const lines = value.split(/\n+/).map((line) => line.trim()).filter(Boolean);
  if (!lines.length) return [];
  const blocks: Array<{ title: string; body: string }> = [];
  let current: { title: string; body: string } | null = null;
  for (const line of lines) {
    const colonMatch = line.match(/^([^:：]{2,28})[:：]\s*(.+)$/);
    if (colonMatch) {
      current = { title: colonMatch[1], body: colonMatch[2] };
      blocks.push(current);
    } else if (current) {
      current.body += `\n${line}`;
    } else {
      blocks.push({ title: "概要", body: line });
    }
  }
  return blocks;
}

