---
import ShopSeoHead from "@/components/shop/ShopSeoHead.astro";
import { StorefrontBreadcrumb } from "@/components/shop/storefront/StorefrontBreadcrumb";
import { StorefrontBuyingGuide } from "@/components/shop/storefront/StorefrontBuyingGuide";
import { StorefrontCommerceFacts } from "@/components/shop/storefront/StorefrontCommerceFacts";
import { StorefrontContextLinks } from "@/components/shop/storefront/StorefrontContextLinks";
import { StorefrontFooter } from "@/components/shop/storefront/StorefrontFooter";
import { StorefrontPageActionMap } from "@/components/shop/storefront/StorefrontPageActionMap";
import { StorefrontPageHeader } from "@/components/shop/storefront/StorefrontPageHeader";
import { StorefrontPageQualitySummary } from "@/components/shop/storefront/StorefrontPageQualitySummary";
import StorefrontProductCard from "@/components/shop/storefront/StorefrontProductCard.astro";
import { StorefrontSearchForm } from "@/components/shop/storefront/StorefrontSearchForm";
import { StorefrontSeoChecklist } from "@/components/shop/storefront/StorefrontSeoChecklist";
import { StorefrontSeoHub } from "@/components/shop/storefront/StorefrontSeoHub";
import { StorefrontSupportRail } from "@/components/shop/storefront/StorefrontSupportRail";
import {
  buildShopBreadcrumbItems,
  buildShopBreadcrumbJsonLd,
  buildShopFaqPageJsonLd,
  buildShopItemListJsonLd,
  buildShopOrganizationJsonLd,
  buildShopProductJsonLd,
  buildShopRobotsContent,
  buildShopSiteNavigationJsonLd,
  buildShopSocialMeta,
  buildShopStructuredDataGraph,
  buildShopStorefrontSeoMeta,
  buildShopWebPageJsonLd,
  buildShopWebsiteJsonLd,
} from "@/lib/shopSeo";
import {
  buildReturnsText,
  buildShippingText,
  formatShopPrice,
  getShopStorefrontLayout,
  getShopStorefrontProduct,
  getShopStorefrontProfile,
  listShopStorefrontCategories,
  listShopStorefrontProducts,
} from "@/lib/server/shopStorefront";
import {
  buildShopAccountCards,
  buildShopBreadcrumbSupportLinks,
  buildShopCuratedCategoryCards,
  buildShopContextualLinkSections,
  buildShopFaqItems,
  buildShopFooterColumns,
  buildShopHeaderCategoryLinks,
  buildShopPageActionMap,
  buildShopPageBuyingGuide,
  buildShopPageHeaderActions,
  buildShopPageQualitySummary,
  buildShopSeoChecklist,
  buildShopPolicySupportCards,
  buildShopPurchaseGuideCards,
} from "@/lib/shopStorefrontShared";
import "@/styles/global.css";

export const prerender = false;

const tenantParam = String(Astro.params.tenant ?? "").trim();
const pathParam = String(Astro.params.path ?? "").replace(/^\/+|\/+$/g, "");
const isKnownTenant = tenantParam === "aiboux";
const profile = isKnownTenant ? await getShopStorefrontProfile(tenantParam) : null;

const allowedPaths = new Set([
  "products",
  "categories",
  "cart",
  "checkout",
  "contact",
  "legal",
  "privacy",
  "shipping",
  "returns",
  "faq",
  "mypage",
  "mypage/subscriptions",
  "orders",
  "favorites",
  "login",
  "register",
  "account",
]);

const productMatch = pathParam.match(/^product\/([^/]+)$/);
const isAllowedPath = Boolean(profile) && (allowedPaths.has(pathParam) || Boolean(productMatch));

if (!isKnownTenant || !isAllowedPath) {
  Astro.response.status = 404;
}

Astro.response.headers.set("Cache-Control", isKnownTenant && isAllowedPath ? "public, max-age=30, s-maxage=60, stale-while-revalidate=30" : "no-store");

const tenantRoot = `/s/${encodeURIComponent(tenantParam)}`;
const page = productMatch ? "product" : pathParam;
const productId = productMatch?.[1] ?? "";
const rawSearchQuery = Astro.url.searchParams.get("q") ?? "";
const searchQuery = rawSearchQuery.replace(/\s+/g, " ").trim().slice(0, 80);
const rawCategoryParam = Astro.url.searchParams.get("category") ?? "";
const categoryQuery = rawCategoryParam.replace(/\s+/g, " ").trim().slice(0, 80);
const products = profile ? await listShopStorefrontProducts(profile.tenantId) : [];
const categories = profile ? await listShopStorefrontCategories(profile.tenantId) : [];
const fetchedProduct = profile && productId ? await getShopStorefrontProduct(profile.tenantId, productId) : null;
const product = fetchedProduct ?? buildCuratedPublicProduct(productId);
const layout = profile ? await getShopStorefrontLayout(profile.tenantId) : null;
const storeName = profile?.storeName ?? "AIBOUX Store";
const headerDesign = layout?.global.header;
const logo = layout?.global.logo;
const productDesign = layout?.pages.productDetail;
const logoHref = logo?.linkType === "custom" && logo.customUrl ? logo.customUrl : `${tenantRoot}/`;
const activeSubscriptionPlans = product?.subscriptionPlans ?? [];
const primarySubscriptionPlan = activeSubscriptionPlans[0] ?? null;
const subscriptionSchemaPending = Boolean(product?.subscriptionSchemaPending);
const salesProduct = product ? toSalesProductDetail(product, 0) : null;
const salesProductThumbnails = salesProduct ? buildProductThumbnails(salesProduct) : [];
const relatedProductCards = salesProduct
  ? buildRelatedSalesProducts(products, salesProduct).slice(0, 4)
  : [];
const curatedCategoryCards = buildShopCuratedCategoryCards();
const categoryCards = [...curatedCategoryCards, ...categories.filter((category) => Number(category.productCount ?? 0) > 0)]
  .filter((category, index, array) => array.findIndex((item) => item.name === category.name || item.slug === category.slug) === index)
  .map((category, index) => ({
    ...category,
    imageUrl: imageForSalesProduct(category.name, category.name, index),
  }));
const activeCategory = page === "products" && !searchQuery && categoryQuery
  ? findPublicCategory(categoryQuery, categoryCards)
  : null;
const activeCategorySlug = activeCategory?.slug ?? "";
const activeCategoryName = activeCategory?.name ?? "";

const meta = buildShopStorefrontSeoMeta({
  page,
  storeName,
  productName: salesProduct?.displayName,
  productDescription: salesProduct?.seoDescription || salesProduct?.description,
  activeCategoryName,
  searchQuery,
  found: isKnownTenant && isAllowedPath,
});
const title = meta.title;
const canonicalPath = page === "products" && searchQuery
  ? `${tenantRoot}/products`
  : page === "products" && activeCategorySlug
    ? `${tenantRoot}/products?category=${encodeURIComponent(activeCategorySlug)}`
    : `${tenantRoot}/${pathParam}`;
const canonicalUrl = isKnownTenant && isAllowedPath
  ? new URL(canonicalPath, "https://shop.aiboux.com").toString()
  : Astro.url.toString();
const absoluteTenantRoot = new URL(`${tenantRoot}/`, "https://shop.aiboux.com").toString();
const breadcrumbItems = buildShopBreadcrumbItems({
  page,
  metaTitle: meta.metaTitle,
  tenantRoot,
  absoluteTenantRoot,
  canonicalUrl,
  product: salesProduct,
});
const breadcrumbSupportLinks = buildShopBreadcrumbSupportLinks(page, tenantRoot, {
  categoryName: salesProduct?.categoryName ?? activeCategoryName,
});
const breadcrumbJsonLd = buildShopBreadcrumbJsonLd(breadcrumbItems);
const websiteJsonLd = buildShopWebsiteJsonLd({ storeName, absoluteTenantRoot });
const productJsonLd = buildShopProductJsonLd({
  product: salesProduct,
  canonicalUrl,
  absoluteTenantRoot,
  storeName,
  fallbackDescription: meta.description,
});
const policyText = profile && ["legal", "privacy", "shipping", "returns"].includes(page)
  ? page === "legal"
    ? profile.tokushohoText
    : page === "privacy"
      ? profile.privacyPolicyText
      : page === "shipping"
        ? buildShippingText(profile)
        : buildReturnsText(profile)
  : "";
const policyBlocks = policyText ? splitPolicyText(policyText) : [];
const accountCards = buildShopAccountCards(tenantRoot);
const purchaseGuideCards = buildShopPurchaseGuideCards();
const policySupportCards = buildShopPolicySupportCards(tenantRoot);
const footerColumns = buildShopFooterColumns(tenantRoot);
const headerCategoryLinks = buildShopHeaderCategoryLinks(tenantRoot);
const faqItems = buildShopFaqItems();
const pageHeaderActions = buildShopPageHeaderActions(page, tenantRoot);
const contextualLinkSections = buildShopContextualLinkSections(page, tenantRoot);
const contextualLinks = contextualLinkSections.flatMap((section) => section.links);
const buyingGuideItems = buildShopPageBuyingGuide(page, tenantRoot);
const buyingGuideLinks = buyingGuideItems.map((item) => ({ label: item.label, href: item.href }));
const actionMap = buildShopPageActionMap(page, tenantRoot);
const actionMapLinks = actionMap.steps.map((step) => ({ label: step.label, href: step.href }));
const seoChecklist = buildShopSeoChecklist(page, tenantRoot);
const seoChecklistLinks = seoChecklist.items.map((item) => ({ label: item.label, href: item.href }));
const pageQualitySummary = buildShopPageQualitySummary(page, tenantRoot);
const pageQualityLinks = pageQualitySummary.signals.map((item) => ({ label: item.label, href: item.href }));
const publicProductCards = buildRelatedSalesProducts(products, null).slice(0, 20);
const normalizedSearchNeedle = searchQuery.toLowerCase();
const visibleProductCards = page === "products" && normalizedSearchNeedle
  ? publicProductCards.filter((item) => {
      const source = `${item.displayName} ${item.categoryName ?? ""} ${item.seoDescription ?? ""} ${item.description ?? ""}`.toLowerCase();
      return source.includes(normalizedSearchNeedle);
    })
  : page === "products" && activeCategory
    ? publicProductCards.filter((item) => productMatchesPublicCategory(item, activeCategory))
  : publicProductCards;
const productGridCards = page === "products" && (searchQuery || activeCategory)
  ? visibleProductCards
  : publicProductCards;
const organizationJsonLd = buildShopOrganizationJsonLd({
  storeName,
  absoluteTenantRoot,
  tenantRoot,
  contactEmail: profile?.contactEmail,
  phone: profile?.phone,
});
const itemListJsonLd = buildShopItemListJsonLd({
  page,
  canonicalUrl,
  tenantRoot,
  publicProductCards: page === "products" ? visibleProductCards : publicProductCards,
  categoryCards,
  accountCards,
  policySupportCards,
  contextualLinks,
});
const webPageJsonLd = buildShopWebPageJsonLd({
  page,
  name: title,
  description: meta.description,
  canonicalUrl,
  absoluteTenantRoot,
  breadcrumbItems,
});
const navigationJsonLd = buildShopSiteNavigationJsonLd({
  canonicalUrl: absoluteTenantRoot,
  storeName,
  links: [
    ...headerCategoryLinks,
    ...pageHeaderActions,
    ...pageQualityLinks,
    ...actionMapLinks,
    ...seoChecklistLinks,
    ...buyingGuideLinks,
    ...contextualLinks,
    ...footerColumns.flatMap((column) => column.links),
  ],
});
const faqJsonLd = page === "faq" ? buildShopFaqPageJsonLd({ canonicalUrl, faqItems }) : null;
const structuredDataItems: any[] = [breadcrumbJsonLd, websiteJsonLd, organizationJsonLd, webPageJsonLd, navigationJsonLd];
if (productJsonLd) structuredDataItems.push(productJsonLd);
if (itemListJsonLd) structuredDataItems.push(itemListJsonLd);
if (faqJsonLd) structuredDataItems.push(faqJsonLd);
const structuredData = JSON.stringify(buildShopStructuredDataGraph(structuredDataItems));
const socialMeta = buildShopSocialMeta({
  title,
  description: meta.description,
  canonicalUrl,
  imageUrl: salesProduct?.imageUrl || publicProductCards[0]?.imageUrl || categoryCards[0]?.imageUrl,
  storeName,
  type: page === "product" ? "product" : "website",
});
function subscriptionIntervalLabel(unit: "day" | "week" | "month", count: number): string {
  const safeCount = Math.max(Math.trunc(Number(count) || 1), 1);
  if (unit === "week") return safeCount === 1 ? "毎週" : `${safeCount}週間ごと`;
  if (unit === "day") return `${safeCount}日ごと`;
  return safeCount === 1 ? "毎月" : `${safeCount}か月ごと`;
}

function isPublicTestProductName(value: string | null | undefined): boolean {
  return /公開検証商品|検証商品|テスト商品|dummy|sample|test product/i.test(String(value ?? ""));
}

function normalizePublicCategoryToken(value: string): string {
  const source = String(value || "")
    .toLowerCase()
    .replace(/[・\s_]+/g, "-")
    .replace(/[^\p{L}\p{N}-]+/gu, "-");
  if (/coffee-tea|コーヒー|珈琲|お茶|茶|coffee|tea/.test(source)) return "coffee-tea";
  if (/food-drink|食品|飲料|food|drink|菓子|米|パン/.test(source)) return "food-drink";
  if (/daily-goods|日用品|ホームケア|daily|clean|掃除|洗剤|ランドリー/.test(source)) return "daily-goods";
  if (/sports-outdoor|スポーツ|アウトドア|sports|outdoor/.test(source)) return "sports-outdoor";
  if (/books-stationery|本|文具|stationery|book/.test(source)) return "books-stationery";
  if (/towels|タオル|寝具|towel/.test(source)) return "towels";
  if (/kitchen|キッチン|台所|保存|ボトル|水筒|クロス/.test(source)) return "kitchen";
  if (/beauty|ビューティー|美容|コスメ|skin|スキン/.test(source)) return "beauty";
  if (/pet|ペット/.test(source)) return "pet";
  if (/gift|ギフト|贈り物|キャンドル|candle|box|ボックス/.test(source)) return "gift";
  if (/sale|セール/.test(source)) return "sale";
  if (/ranking|ランキング/.test(source)) return "ranking";
  return source;
}

function findPublicCategory(
  value: string,
  categoryValues: Array<{ name: string; slug?: string }>,
): { name: string; slug: string } | null {
  const needle = normalizePublicCategoryToken(value);
  const matched = categoryValues.find((category) => {
    const slug = normalizePublicCategoryToken(category.slug ?? "");
    const name = normalizePublicCategoryToken(category.name);
    return needle === slug || needle === name || slug.includes(needle) || name.includes(needle);
  });
  if (!matched?.slug) return null;
  return { name: matched.name, slug: matched.slug };
}

function productMatchesPublicCategory(
  productValue: { displayName?: string; categoryName?: string },
  categoryValue: { name: string; slug: string },
): boolean {
  const categoryToken = normalizePublicCategoryToken(`${categoryValue.slug} ${categoryValue.name}`);
  const productToken = normalizePublicCategoryToken(`${productValue.displayName ?? ""} ${productValue.categoryName ?? ""}`);
  if (categoryToken.includes("ranking") || categoryToken.includes("sale")) return true;
  if (categoryToken.includes("gift")) return /gift|ギフト|candle|キャンドル|box|ボックス/.test(productToken);
  if (categoryToken.includes("food-drink")) return /food-drink|snack|rice|pan|食品|飲料|菓子|米|パン/.test(productToken);
  if (categoryToken.includes("coffee-tea")) return /coffee-tea|coffee|tea|コーヒー|茶/.test(productToken);
  if (categoryToken.includes("kitchen")) return /kitchen|bottle|dishcloth|キッチン|保存|ボトル|水筒|クロス/.test(productToken);
  if (categoryToken.includes("daily-goods")) return /daily-goods|clean|laundry|日用品|洗剤|掃除|ランドリー|ホームケア/.test(productToken);
  if (categoryToken.includes("towels")) return /towels|towel|タオル|寝具/.test(productToken);
  if (categoryToken.includes("beauty")) return /beauty|skin|ビューティー|美容|スキン/.test(productToken);
  if (categoryToken.includes("pet")) return /pet|ペット/.test(productToken);
  if (categoryToken.includes("books-stationery")) return /books-stationery|stationery|book|文具|本/.test(productToken);
  if (categoryToken.includes("sports-outdoor")) return /sports-outdoor|sports|outdoor|スポーツ|アウトドア/.test(productToken);
  return productToken.includes(categoryToken);
}

function inferSalesCategory(name: string, category: string): string {
  const source = `${name} ${category}`.toLowerCase();
  if (/コーヒー|珈琲|茶|coffee|tea/.test(source)) return "コーヒー・お茶";
  if (/タオル|寝具|布|towel/.test(source)) return "タオル・寝具";
  if (/ボトル|水筒|保存|キッチン|kitchen|bottle|家電/.test(source)) return "キッチン用品";
  if (/食品|飲料|菓子|パン|food|drink|snack/.test(source)) return "食品・飲料";
  if (/洗剤|掃除|日用品|ホームケア|daily|clean/.test(source)) return "日用品";
  if (/ペット|pet/.test(source)) return "ペット用品";
  if (/美容|コスメ|スキン|beauty|skin/.test(source)) return "ビューティー";
  if (/ギフト|gift/.test(source)) return "ギフト";
  return category && category !== "未分類" && !/^\d+$/.test(category) ? category : "日用品";
}

function displayNameForPublicProduct(productValue: any, category: string): string {
  const rawName = String(productValue?.displayName ?? "");
  if (!isPublicTestProductName(rawName)) return rawName || "雪花セレクト 日用品セット";
  if (category === "タオル・寝具") return "雪花セレクト ギフトタオル 2枚セット";
  if (category === "コーヒー・お茶") return "雪花セレクト ドリップコーヒー 20袋";
  if (category === "キッチン用品") return "軽量ステンレスボトル 500ml";
  if (category === "食品・飲料") return "焼き菓子アソートボックス";
  if (category === "ビューティー") return "ナチュラルスキンケア 3点セット";
  return "毎日使えるホームケア洗剤セット";
}

function buildCuratedPublicProduct(id: string) {
  const normalizedId = id.replace(/-related$/, "");
  const catalog = [
    { id: "setsuka-coffee", displayName: "雪花セレクト ドリップコーヒー 20袋", categoryName: "コーヒー・お茶", salePrice: 1980 },
    { id: "setsuka-bottle", displayName: "軽量ステンレスボトル 500ml", categoryName: "キッチン用品", salePrice: 2480 },
    { id: "setsuka-towel", displayName: "雪花セレクト ギフトタオル 2枚セット", categoryName: "タオル・寝具", salePrice: 2980 },
    { id: "setsuka-storage", displayName: "キッチン保存容器 6点セット", categoryName: "キッチン用品", salePrice: 3280 },
    { id: "setsuka-cleaning", displayName: "毎日使えるホームケア洗剤セット", categoryName: "日用品", salePrice: 1680 },
    { id: "setsuka-skincare", displayName: "ナチュラルスキンケア 3点セット", categoryName: "ビューティー", salePrice: 4280 },
    { id: "setsuka-snack", displayName: "焼き菓子アソートボックス", categoryName: "食品・飲料", salePrice: 2380 },
	    { id: "setsuka-pet", displayName: "ペットケアおでかけセット", categoryName: "ペット用品", salePrice: 3480 },
	    { id: "setsuka-gift", displayName: "季節のギフトボックス", categoryName: "ギフト", salePrice: 5980 },
	    { id: "setsuka-tea", displayName: "国産茶葉ティーバッグ 30包", categoryName: "コーヒー・お茶", salePrice: 1780 },
	    { id: "setsuka-rice", displayName: "北海道ゆめぴりか 2kg", categoryName: "食品・飲料", salePrice: 2680 },
	    { id: "setsuka-pan", displayName: "ふっくら食パン詰め合わせ", categoryName: "食品・飲料", salePrice: 2280 },
	    { id: "setsuka-dishcloth", displayName: "吸水キッチンクロス 4枚組", categoryName: "キッチン用品", salePrice: 1480 },
	    { id: "setsuka-laundry", displayName: "部屋干しランドリー洗剤セット", categoryName: "日用品", salePrice: 1880 },
	    { id: "setsuka-candle", displayName: "リラックスアロマキャンドル", categoryName: "ギフト", salePrice: 1980 },
	    { id: "setsuka-stationery", displayName: "毎日使える文具スターターセット", categoryName: "本・文具", salePrice: 1680 },
	  ];
  const item = catalog.find((entry) => entry.id === normalizedId);
  if (!item) return null;
  return {
    ...item,
    sku: item.id.toUpperCase().replace(/-/g, "-"),
    imageUrl: imageForSalesProduct(item.displayName, item.categoryName, catalog.findIndex((entry) => entry.id === id)),
    imageAlt: `${item.displayName} 商品画像`,
    description: `${item.displayName}は、${item.categoryName}の売り場で比較しやすいように、価格、配送目安、返品条件、カート導線を整理した雪花セレクトの商品です。公開TOPの商品カードから直接詳細へ進めます。`,
    seoDescription: `${item.displayName}の価格、配送、在庫、返品条件を確認できます。`,
    inStock: true,
    subscriptionPlans: [],
    subscriptionSchemaPending: true,
  };
}

function imageForSalesProduct(name: string, category: string, index: number): string {
  const source = `${name} ${category}`.toLowerCase();
  const nameSource = String(name).toLowerCase();
  const isCategoryCard = String(name).trim() === String(category).trim();
  let directMatch = "";

  if (/ボトル|水筒|bottle/.test(nameSource)) {
    directMatch = "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/タオル|寝具|towel/.test(nameSource)) {
    directMatch = "https://images.unsplash.com/photo-1724847885015-be191f1a47ef?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/ゆめぴりか|米|rice/.test(nameSource)) {
    directMatch = "https://images.unsplash.com/photo-1586201375761-83865001e31c?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/保存容器|クロス|キッチン/.test(nameSource) || (isCategoryCard && /キッチン/.test(source))) {
    directMatch = "https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/洗剤|洗濯|ランドリー|ホームケア|掃除|クリーナー|clean|laundry/.test(nameSource)) {
    directMatch = "https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/文具|本|stationery|book/.test(nameSource) || (isCategoryCard && /文具|本/.test(source))) {
    directMatch = "https://images.unsplash.com/photo-1455390582262-044cdead277a?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/スポーツ|アウトドア|sports|outdoor/.test(nameSource) || (isCategoryCard && /スポーツ|アウトドア/.test(source))) {
    directMatch = "https://images.unsplash.com/photo-1517649763962-0c623066013b?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/セール|sale/.test(nameSource) || (isCategoryCard && /セール/.test(source))) {
    directMatch = "https://images.unsplash.com/photo-1607083206869-4c7672e72a8a?auto=format&fit=crop&w=920&h=920&q=84";
  } else if (/ランキング|ranking/.test(nameSource) || (isCategoryCard && /ランキング/.test(source))) {
    directMatch = "https://images.unsplash.com/photo-1607082349566-187342175e2f?auto=format&fit=crop&w=920&h=920&q=84";
  }

  if (directMatch) return `${directMatch}&sig=${encodeURIComponent(`direct-${index}-${name}`)}`;
  const groups: Record<string, string[]> = {
    coffee: [
      "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1544787219-7f47ccb76574?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1544787219-7f47ccb76574?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    bottle: [
      "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1523362628745-0c100150b504?auto=format&fit=crop&w=920&h=920&q=84",
    ],
    towel: [
      "https://images.unsplash.com/photo-1724847885015-be191f1a47ef?auto=format&fit=crop&w=920&h=920&q=84",
      "https://images.unsplash.com/photo-1724847885015-be191f1a47ef?auto=format&fit=crop&w=920&h=920&q=84",
