    .filter((item, index, array) => array.findIndex((next) => next.displayName === item.displayName) === index);
  const fallback = [
    { id: "setsuka-coffee", displayName: "雪花セレクト ドリップコーヒー 20袋", categoryName: "コーヒー・お茶", salePrice: 1980, imageUrl: imageForSalesProduct("雪花セレクト ドリップコーヒー 20袋", "コーヒー・お茶", 1) },
    { id: "setsuka-bottle", displayName: "軽量ステンレスボトル 500ml", categoryName: "キッチン用品", salePrice: 2480, imageUrl: imageForSalesProduct("軽量ステンレスボトル 500ml", "キッチン用品", 1) },
