    }
    {isKnownTenant && isAllowedPath ? <StorefrontFooter storeName={storeName} tenantRoot={tenantRoot} /> : null}
    <script is:inline define:vars={{ tenantRoot }}>
      const CART_KEY = "aiboux:shop:aiboux:cart";

      function readCart() {
        try {
          const parsed = JSON.parse(localStorage.getItem(CART_KEY) || "[]");
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }

      function writeCart(items) {
        localStorage.setItem(CART_KEY, JSON.stringify(items));
      }

      function formatYen(value) {
        return `¥${Math.max(0, Number(value) || 0).toLocaleString("ja-JP")}`;
      }

      function cartImageForName(name) {
        const source = String(name || "").toLowerCase();
        if (/ボトル|水筒|bottle/.test(source)) return "https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&w=240&h=240&q=82";
        if (/タオル|寝具|towel/.test(source)) return "https://images.unsplash.com/photo-1724847885015-be191f1a47ef?auto=format&fit=crop&w=240&h=240&q=82";
        if (/洗剤|洗濯|ランドリー|ホームケア|掃除|クリーナー|clean|laundry/.test(source)) return "https://images.unsplash.com/photo-1585421514284-efb74c2b69ba?auto=format&fit=crop&w=240&h=240&q=82";
        if (/コーヒー|茶|coffee|tea/.test(source)) return "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=240&h=240&q=82";
        if (/ギフト|gift/.test(source)) return "https://images.unsplash.com/photo-1513885535751-8b9238bd345a?auto=format&fit=crop&w=240&h=240&q=82";
        if (/キッチン|保存|クロス|kitchen/.test(source)) return "https://images.unsplash.com/photo-1556911220-bff31c812dba?auto=format&fit=crop&w=240&h=240&q=82";
        return "https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&w=240&h=240&q=82";
      }

      function addToCart(product, redirectPath = `${tenantRoot}/cart`) {
        const items = readCart();
        const existing = items.find((item) => item.id === product.id);
        const quantity = Math.min(99, Math.max(1, Number(product.quantity || 1)));
        if (existing) {
          existing.quantity = Math.min(99, Number(existing.quantity || 0) + quantity);
        } else {
          items.push({ ...product, quantity });
        }
        writeCart(items);
        window.location.href = redirectPath;
      }

      function buildCartProductFromButton(button) {
        const selectedMode = document.querySelector("input[name='purchase_mode']:checked");
        const planSelect = document.querySelector("[data-subscription-plan-select]");
        const quantityInput = document.querySelector("[data-product-quantity]");
        const purchaseMode = selectedMode instanceof HTMLInputElement ? selectedMode.value : "normal";
        const selectedOption = planSelect instanceof HTMLSelectElement ? planSelect.selectedOptions[0] : null;
        const subscriptionPrice = Number(selectedOption?.getAttribute("data-price") || button.getAttribute("data-subscription-price") || 0);
        const quantity = quantityInput instanceof HTMLInputElement ? Math.min(99, Math.max(1, Number.parseInt(quantityInput.value, 10) || 1)) : 1;
        return {
          id: purchaseMode === "subscription"
            ? `${button.getAttribute("data-product-id") || ""}:${selectedOption?.value || button.getAttribute("data-subscription-plan-id") || "subscription"}`
            : button.getAttribute("data-product-id") || "",
          productId: button.getAttribute("data-product-id") || "",
          name: button.getAttribute("data-product-name") || "",
          price: purchaseMode === "subscription" && subscriptionPrice > 0 ? subscriptionPrice : Number(button.getAttribute("data-product-price") || 0),
          image: button.getAttribute("data-product-image") || "",
          purchaseMode,
          quantity,
          subscriptionPlanId: purchaseMode === "subscription" ? selectedOption?.value || button.getAttribute("data-subscription-plan-id") || "" : "",
          subscriptionPlanName: purchaseMode === "subscription" ? selectedOption?.textContent?.trim() || button.getAttribute("data-subscription-plan-name") || "定期プラン" : "",
          subscriptionInterval: purchaseMode === "subscription" ? selectedOption?.getAttribute("data-interval") || button.getAttribute("data-subscription-interval") || "" : "",
        };
      }

      function renderCart() {
        const list = document.querySelector("[data-cart-list]");
        const empty = document.querySelector("[data-cart-empty]");
        const summary = document.querySelector("[data-cart-summary]");
        const subtotalNode = document.querySelector("[data-cart-subtotal]");
        const totalItemsNode = document.querySelector("[data-cart-total-items]");
        const grandTotalNode = document.querySelector("[data-cart-grand-total]");
        const subscriptionSummary = document.querySelector("[data-cart-subscription-summary]");
        if (!list || !empty || !summary || !subtotalNode) return;
        const items = readCart();
        if (!items.length) {
          list.classList.add("hidden");
          summary.classList.add("hidden");
          empty.classList.remove("hidden");
          list.innerHTML = "";
          return;
        }
        empty.classList.add("hidden");
        list.classList.remove("hidden");
        summary.classList.remove("hidden");
        list.innerHTML = items.map((item) => `
          <div class="grid gap-3 rounded-lg border border-neutral-200 p-3 sm:grid-cols-[64px_1fr_auto]">
            <div class="flex size-16 items-center justify-center rounded-md bg-neutral-50">
              <img src="${escapeHtml(item.image || cartImageForName(item.name))}" alt="${escapeHtml(item.name || "カート商品")} 商品画像" class="h-full w-full rounded-md object-cover" />
            </div>
            <div>
              <div class="text-sm font-semibold text-neutral-950">${escapeHtml(item.name)}</div>
              <div class="mt-1 text-sm text-neutral-600">${formatYen(item.price)}${item.purchaseMode === "subscription" ? ` / ${escapeHtml(item.subscriptionInterval || "")}` : ""}</div>
              ${item.purchaseMode === "subscription" ? `<div class="mt-1 inline-flex rounded bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-800">定期購入: ${escapeHtml(item.subscriptionPlanName || "定期プラン")}</div>` : ""}
              <label class="mt-2 inline-flex items-center gap-2 text-xs text-neutral-600">数量
                <input class="h-8 w-20 rounded-md border border-neutral-200 px-2" data-cart-qty="${escapeHtml(item.id)}" inputmode="numeric" value="${Number(item.quantity || 1)}" />
              </label>
            </div>
            <button class="h-8 rounded-md border border-neutral-300 px-3 text-xs font-semibold" data-cart-remove="${escapeHtml(item.id)}" type="button">削除</button>
          </div>
        `).join("");
        const totalItems = items.reduce((sum, item) => sum + Math.max(1, Number(item.quantity || 1)), 0);
        const subtotal = items.reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 0), 0);
        subtotalNode.textContent = formatYen(subtotal);
        if (totalItemsNode) totalItemsNode.textContent = `${totalItems}点`;
        if (grandTotalNode) grandTotalNode.textContent = formatYen(subtotal);
        if (subscriptionSummary) {
          const subscriptionItems = items.filter((item) => item.purchaseMode === "subscription");
          subscriptionSummary.textContent = subscriptionItems.length
            ? `定期購入 ${subscriptionItems.length}件 / 次回以降合計 ${formatYen(subscriptionItems.reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 0), 0))}`
            : "";
        }
      }

      function renderCheckout() {
        const node = document.querySelector("[data-checkout-items]");
        if (!node) return;
        const items = readCart();
        if (!items.length) {
          node.innerHTML = `
            <div class="rounded-lg border border-dashed border-neutral-300 bg-neutral-50 p-4" data-testid="storefront-checkout-empty-guide">
              <div class="font-bold text-neutral-950">カートに商品がありません</div>
              <p class="mt-2 text-sm leading-6 text-neutral-600">商品を追加すると、数量、小計、配送・返品条件、支払い方法をこの画面で確認できます。</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <a class="inline-flex h-9 items-center rounded-full bg-amber-400 px-4 text-xs font-bold text-neutral-950" href="${tenantRoot}/products">商品一覧へ戻る</a>
                <a class="inline-flex h-9 items-center rounded-md border border-neutral-300 bg-white px-4 text-xs font-bold text-blue-700" href="${tenantRoot}/cart">カートを確認</a>
                <a class="inline-flex h-9 items-center rounded-md border border-neutral-300 bg-white px-4 text-xs font-bold text-blue-700" href="${tenantRoot}/shipping">配送条件を見る</a>
              </div>
            </div>
          `;
          return;
        }
        const totalItems = items.reduce((sum, item) => sum + Math.max(1, Number(item.quantity || 1)), 0);
        const subtotal = items.reduce((sum, item) => sum + Number(item.price || 0) * Number(item.quantity || 0), 0);
        node.innerHTML = `
          <div class="space-y-2">
            ${items.map((item) => `<div class="flex justify-between gap-3 border-b border-neutral-100 pb-2"><span>${escapeHtml(item.name)} x ${Number(item.quantity || 1)}${item.purchaseMode === "subscription" ? `<br><span class="text-xs text-amber-700">定期購入 / ${escapeHtml(item.subscriptionInterval || "")}</span>` : ""}</span><strong>${formatYen(Number(item.price || 0) * Number(item.quantity || 0))}</strong></div>`).join("")}
            <div class="flex justify-between pt-2 text-neutral-700"><span>商品点数</span><strong data-checkout-total-items>${totalItems}点</strong></div>
            <div class="flex justify-between text-neutral-950"><span>注文合計</span><strong data-checkout-grand-total class="text-lg text-red-700">${formatYen(subtotal)}</strong></div>
          </div>
        `;
        const hasSubscription = items.some((item) => item.purchaseMode === "subscription");
        document.querySelectorAll("[data-subscription-payment-blocker], [data-subscription-terms], [data-subscription-submit]").forEach((element) => {
          element.classList.toggle("hidden", !hasSubscription);
          if (element.hasAttribute("data-subscription-terms")) element.classList.toggle("flex", hasSubscription);
          if (element.hasAttribute("data-subscription-submit")) element.classList.toggle("inline-flex", hasSubscription);
        });
      }

      function escapeHtml(value) {
        return String(value || "").replace(/[&<>"']/g, (char) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[char]);
      }

      document.querySelectorAll("[data-cart-add]").forEach((button) => {
        button.addEventListener("click", () => {
          addToCart(buildCartProductFromButton(button));
        });
      });

      document.querySelectorAll("[data-buy-now]").forEach((button) => {
        button.addEventListener("click", () => {
          addToCart(buildCartProductFromButton(button), `${tenantRoot}/checkout`);
        });
      });

      const productQuantityInput = document.querySelector("[data-product-quantity]");
      function normalizeProductQuantity(nextValue) {
        if (!(productQuantityInput instanceof HTMLInputElement)) return;
        productQuantityInput.value = String(Math.min(99, Math.max(1, Number.parseInt(String(nextValue), 10) || 1)));
      }
      if (productQuantityInput instanceof HTMLInputElement) {
        productQuantityInput.addEventListener("input", () => normalizeProductQuantity(productQuantityInput.value));
        productQuantityInput.addEventListener("blur", () => normalizeProductQuantity(productQuantityInput.value));
      }
      document.querySelector("[data-product-quantity-decrease]")?.addEventListener("click", () => {
        if (productQuantityInput instanceof HTMLInputElement) normalizeProductQuantity(Number(productQuantityInput.value || 1) - 1);
      });
      document.querySelector("[data-product-quantity-increase]")?.addEventListener("click", () => {
        if (productQuantityInput instanceof HTMLInputElement) normalizeProductQuantity(Number(productQuantityInput.value || 1) + 1);
      });

      const productMainImage = document.querySelector("[data-testid='product-main-image']");
      const productThumbnails = Array.from(document.querySelectorAll("[data-product-thumbnail]"));
      function activateProductThumbnail(button) {
        if (!(productMainImage instanceof HTMLImageElement) || !(button instanceof HTMLElement)) return;
        const image = button.getAttribute("data-gallery-image") || "";
        const alt = button.getAttribute("data-gallery-alt") || "";
        if (!image) return;
        productMainImage.src = image;
        if (alt) productMainImage.alt = alt;
        productThumbnails.forEach((node) => {
          const active = node === button;
          node.setAttribute("data-active", active ? "true" : "false");
          node.setAttribute("aria-pressed", active ? "true" : "false");
        });
      }
      productThumbnails.forEach((button, index) => {
        button.addEventListener("click", () => activateProductThumbnail(button));
        button.addEventListener("keydown", (event) => {
          if (!(event instanceof KeyboardEvent)) return;
          if (event.key !== "ArrowDown" && event.key !== "ArrowRight" && event.key !== "ArrowUp" && event.key !== "ArrowLeft") return;
          event.preventDefault();
          const delta = event.key === "ArrowDown" || event.key === "ArrowRight" ? 1 : -1;
          const nextIndex = (index + delta + productThumbnails.length) % productThumbnails.length;
          const nextButton = productThumbnails[nextIndex];
          if (nextButton instanceof HTMLElement) {
            nextButton.focus();
            activateProductThumbnail(nextButton);
          }
        });
      });

      document.addEventListener("input", (event) => {
        const input = event.target;
        if (!(input instanceof HTMLInputElement) || !input.matches("[data-cart-qty]")) return;
        const id = input.getAttribute("data-cart-qty");
        const nextQuantity = Math.min(99, Math.max(1, Number.parseInt(input.value, 10) || 1));
        const items = readCart().map((item) => item.id === id ? { ...item, quantity: nextQuantity } : item);
        writeCart(items);
        renderCart();
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement) || !target.matches("[data-cart-remove]")) return;
        const id = target.getAttribute("data-cart-remove");
        writeCart(readCart().filter((item) => item.id !== id));
        renderCart();
      });

      const subscriptionSubmit = document.querySelector("[data-subscription-submit]");
      if (subscriptionSubmit instanceof HTMLButtonElement) {
        subscriptionSubmit.addEventListener("click", async () => {
          const resultNode = document.querySelector("[data-subscription-result]");
          const subscriptionItem = readCart().find((item) => item.purchaseMode === "subscription");
          const termsCheckbox = document.querySelector("[data-subscription-terms-checkbox]");
          if (!subscriptionItem) return;
          if (termsCheckbox instanceof HTMLInputElement && !termsCheckbox.checked) {
            if (resultNode instanceof HTMLElement) {
              resultNode.classList.remove("hidden");
              resultNode.textContent = "定期購入規約、解約ポリシー、次回配送予定を確認してください。";
            }
            return;
          }
          subscriptionSubmit.disabled = true;
            if (resultNode instanceof HTMLElement) {
              resultNode.classList.remove("hidden");
            resultNode.textContent = "定期購入の支払い方法の受付条件を確認しています。";
            }
          try {
            const response = await fetch("/shop/api/checkout/subscription?tenant=aiboux", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                productId: subscriptionItem.productId,
                planId: subscriptionItem.subscriptionPlanId,
                quantity: subscriptionItem.quantity,
                customerName: "公開チェックアウト確認",
                customerEmail: "subscription-check@example.invalid",
              }),
            });
            const data = await response.json().catch(() => ({}));
            if (resultNode instanceof HTMLElement) {
              resultNode.textContent = data?.error
                ? String(data.error)
                : response.ok
                  ? "定期購入申込みを受け付けました。"
                  : "定期購入申込みの条件を確認してください。";
            }
          } catch {
            if (resultNode instanceof HTMLElement) {
              resultNode.textContent = "定期購入申込みの条件を確認できませんでした。";
            }
          } finally {
            subscriptionSubmit.disabled = false;
          }
        });
      }

      const contactForm = document.querySelector("[data-contact-form]");
      if (contactForm instanceof HTMLFormElement) {
        contactForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const status = contactForm.querySelector("[data-contact-status]");
          const form = new FormData(contactForm);
          const name = String(form.get("name") || "").trim();
          const email = String(form.get("email") || "").trim();
          const topic = String(form.get("topic") || "").trim();
          const message = String(form.get("message") || "").trim();
          const errors = [];
          if (!name) errors.push("お名前を入力してください。");
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push("正しいメールアドレスを入力してください。");
          if (!topic) errors.push("問い合わせ種別を選択してください。");
          if (!message) errors.push("内容を入力してください。");
          if (status instanceof HTMLElement) {
            status.classList.remove("hidden", "border-emerald-200", "bg-emerald-50", "text-emerald-700", "border-red-200", "bg-red-50", "text-red-700", "border-amber-200", "bg-amber-50", "text-amber-800");
            if (errors.length) {
              status.classList.add("border-red-200", "bg-red-50", "text-red-700");
              status.textContent = errors.join(" ");
            } else {
              status.classList.add("border-amber-200", "bg-amber-50", "text-amber-800");
              status.textContent = "入力内容は確認できました。送信受付の状態を確認し、必要に応じてストアへ連絡してください。";
            }
          }
        });
      }

      const checkoutCustomerForm = document.querySelector("[data-checkout-customer-form]");
      if (checkoutCustomerForm instanceof HTMLFormElement) {
        checkoutCustomerForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const status = checkoutCustomerForm.querySelector("[data-checkout-customer-status]");
          const form = new FormData(checkoutCustomerForm);
          const name = String(form.get("customerName") || "").trim();
          const email = String(form.get("customerEmail") || "").trim();
          const address = String(form.get("shippingAddress") || "").trim();
          const errors = [];
          if (!name) errors.push("お名前を入力してください。");
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push("正しいメールアドレスを入力してください。");
          if (address.length < 8) errors.push("配送先住所を入力してください。");
          if (status instanceof HTMLElement) {
            status.classList.remove("hidden", "border-emerald-200", "bg-emerald-50", "text-emerald-700", "border-red-200", "bg-red-50", "text-red-700");
            if (errors.length) {
              status.classList.add("border-red-200", "bg-red-50", "text-red-700");
              status.textContent = errors.join(" ");
            } else {
              status.classList.add("border-emerald-200", "bg-emerald-50", "text-emerald-700");
              status.textContent = "配送先と連絡先を確認しました。注文内容、配送条件、支払い方法を続けて確認してください。";
            }
          }
        });
      }

      const orderSearchForm = document.querySelector("[data-order-search-form]");
      if (orderSearchForm instanceof HTMLFormElement) {
        orderSearchForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const status = orderSearchForm.querySelector("[data-order-search-status]");
          const form = new FormData(orderSearchForm);
          const orderNumber = String(form.get("orderNumber") || "").trim();
          const email = String(form.get("orderEmail") || "").trim();
          const errors = [];
          if (!orderNumber && !email) errors.push("注文番号またはメールアドレスを入力してください。");
          if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push("正しいメールアドレスを入力してください。");
          if (status instanceof HTMLElement) {
            status.classList.remove("hidden", "border-emerald-200", "bg-emerald-50", "text-emerald-700", "border-red-200", "bg-red-50", "text-red-700", "border-amber-200", "bg-amber-50", "text-amber-800");
            if (errors.length) {
              status.classList.add("border-red-200", "bg-red-50", "text-red-700");
              status.textContent = errors.join(" ");
            } else {
              status.classList.add("border-amber-200", "bg-amber-50", "text-amber-800");
              status.innerHTML = `
                <span class="block font-semibold">入力内容を確認しました。</span>
                <span class="mt-1 block">注文番号とメールを添えて、配送状況や領収書の確認へ進めます。</span>
                <span class="mt-2 flex flex-wrap gap-2">
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/contact">問い合わせへ進む</a>
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/shipping">配送条件を見る</a>
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/returns">返品条件を見る</a>
                </span>
              `;
            }
          }
        });
      }

      const authForms = document.querySelectorAll("[data-auth-form]");
      authForms.forEach((authForm) => {
        if (!(authForm instanceof HTMLFormElement)) return;
        authForm.addEventListener("submit", (event) => {
          event.preventDefault();
          const status = authForm.querySelector("[data-auth-status]");
          const form = new FormData(authForm);
          const email = String(form.get("email") || "").trim();
          const password = String(form.get("password") || "").trim();
          const errors = [];
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push("正しいメールアドレスを入力してください。");
          if (password.length < 8) errors.push("パスワードは8文字以上で入力してください。");
          if (status instanceof HTMLElement) {
            status.classList.remove("hidden", "border-emerald-200", "bg-emerald-50", "text-emerald-700", "border-red-200", "bg-red-50", "text-red-700", "border-amber-200", "bg-amber-50", "text-amber-800");
            if (errors.length) {
              status.classList.add("border-red-200", "bg-red-50", "text-red-700");
              status.textContent = errors.join(" ");
            } else {
              status.classList.add("border-amber-200", "bg-amber-50", "text-amber-800");
              status.innerHTML = `
                <span class="block font-semibold">入力内容を確認しました。</span>
                <span class="mt-1 block">注文履歴や問い合わせは、マイページの各入口から確認できます。</span>
                <span class="mt-2 flex flex-wrap gap-2">
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/mypage">マイページへ</a>
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/orders">注文履歴へ</a>
                  <a class="font-bold text-blue-700 underline underline-offset-2" href="${tenantRoot}/favorites">お気に入りへ</a>
                </span>
              `;
            }
          }
        });
      });

      renderCart();
      renderCheckout();
    </script>
  </body>
</html>
