---
import PricingCards from "@/components/file/PricingCards.astro";
import FileToolLayout from "@/layouts/FileToolLayout.astro";
import { filePricingPlans } from "@/data/pricing";

export const prerender = true;
---

<FileToolLayout
  title="料金プラン"
  description="無料プランと月500円のPlus Liteを、必要な機能に合わせて選べます。"
>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-5 lg:px-6">
    <PricingCards plans={filePricingPlans} />
  </section>
</FileToolLayout>
