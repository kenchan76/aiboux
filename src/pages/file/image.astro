---
import AdSlot from "@/components/file/AdSlot.astro";
import ImageToolGrid from "@/components/tools/ImageToolGrid.astro";
import FileToolLayout from "@/layouts/FileToolLayout.astro";

export const prerender = true;
---

<FileToolLayout
  title="画像ツール"
  description="画像圧縮、リサイズ、WebP変換、JPG/PNG変換、背景透過、商品写真モードをまとめています。"
>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-5 lg:px-6">
    <ImageToolGrid />
    <div class="mt-5"><AdSlot /></div>
  </section>
</FileToolLayout>
