---
import AdSlot from "@/components/file/AdSlot.astro";
import ToolCard from "@/components/file/ToolCard.astro";
import FileToolLayout from "@/layouts/FileToolLayout.astro";
import { fileTools } from "@/data/file-tools";

export const prerender = true;
---

<FileToolLayout
  title="ツール一覧"
  description="ファイル転送、PDF、画像処理、背景透過、バーコード作成をまとめたAIBOUX FILEのツール一覧です。"
>
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-5 lg:px-6">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {fileTools.map((tool) => <ToolCard tool={tool} />)}
    </div>
    <div class="mt-5"><AdSlot /></div>
  </section>
</FileToolLayout>
