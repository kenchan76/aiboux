---
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";
import "@/styles/global.css";

export const prerender = false;

const tenantSlug = "aiboux";
---

<!doctype html>
<html lang="ja" class="bg-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <NotoSansJpHead />
    <meta name="color-scheme" content="light" />
    <title>AIBOUX Mail | サービスサイト</title>
    <meta name="description" content="AIBOUX Mailは、業務メール、テンプレート、迷惑メール対策、添付ファイル連携を扱うAIBOUXシリーズのメールサービスです。" />
  </head>
  <body class="min-h-screen bg-white text-neutral-950 antialiased">
    <header class="border-b border-neutral-200 bg-white">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3">
        <a href="/" class="flex items-center gap-2" aria-label="AIBOUX Mail">
          <span class="text-xl font-semibold tracking-tight">AIBOUX Mail</span>
          <span class="rounded-md border border-blue-200 bg-blue-50 px-2 py-1 text-xs font-semibold text-blue-700">Service</span>
        </a>
        <nav class="hidden items-center gap-5 text-sm font-medium text-neutral-600 md:flex">
          <a class="hover:text-neutral-950" href="#features">機能</a>
          <a class="hover:text-neutral-950" href="#tenant">テナント</a>
          <a class="hover:text-neutral-950" href="https://docs.aiboux.com/">Docs</a>
        </nav>
        <a class="rounded-md bg-blue-700 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-800" href={`/s/${tenantSlug}/`}>
          テナント画面を開く
        </a>
      </div>
    </header>

    <main>
      <section class="border-b border-neutral-200 bg-neutral-50">
        <div class="mx-auto grid max-w-7xl gap-8 px-5 py-10 lg:grid-cols-[1fr_460px] lg:items-center">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">AIBOUX Service Site</p>
            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-neutral-950 md:text-4xl">AIBOUX Mail</h1>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-neutral-700">
              業務メール、自動分類、共有テンプレート、迷惑対策をAIBOUXシリーズの業務データとつなぐメールサービスです。
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a class="rounded-md bg-blue-700 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-800" href={`/s/${tenantSlug}/`}>
                aiboux テナント
              </a>
              <a class="rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-semibold text-neutral-800 hover:bg-neutral-100" href="https://docs.aiboux.com/">
                ドキュメント
              </a>
            </div>
          </div>
          <div class="rounded-md border border-neutral-200 bg-white">
            <div class="border-b border-neutral-200 px-4 py-3 text-sm font-semibold">サービス入口</div>
            <dl class="divide-y divide-neutral-200 text-sm">
              <div class="grid grid-cols-[120px_1fr] gap-4 px-4 py-3">
                <dt class="font-medium text-neutral-500">サービス</dt>
                <dd class="text-neutral-900">mail.aiboux.com</dd>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 px-4 py-3">
                <dt class="font-medium text-neutral-500">テナント</dt>
                <dd><a class="font-semibold text-blue-700 hover:text-blue-800" href={`/s/${tenantSlug}/`}>/s/{tenantSlug}/</a></dd>
              </div>
              <div class="grid grid-cols-[120px_1fr] gap-4 px-4 py-3">
                <dt class="font-medium text-neutral-500">画面種別</dt>
                <dd class="text-neutral-900">管理/業務画面</dd>
              </div>
            </dl>
          </div>
        </div>
      </section>

      <section id="features" class="mx-auto max-w-7xl px-5 py-8">
        <h2 class="text-lg font-semibold tracking-tight">主な機能</h2>
        <div class="mt-4 grid gap-3 md:grid-cols-2 lg:grid-cols-4">
          {["業務メール", "共有テンプレート", "迷惑対策", "添付連携"].map((item) => (
            <div class="rounded-md border border-neutral-200 bg-white p-4">
              <div class="text-sm font-semibold text-neutral-950">{item}</div>
              <p class="mt-2 text-xs leading-5 text-neutral-600">AIBOUXの業務画面としてテナント単位で利用します。</p>
            </div>
          ))}
        </div>
      </section>

      <section id="tenant" class="border-t border-neutral-200 bg-white">
        <div class="mx-auto max-w-7xl px-5 py-8">
          <h2 class="text-lg font-semibold tracking-tight">テナントURL</h2>
          <p class="mt-2 text-sm leading-6 text-neutral-600">サービス直下はこのサービスサイトです。テナント画面は <code class="rounded bg-neutral-100 px-1 py-0.5">/s/{"{tenant}"}</code> 配下で開きます。</p>
          <a class="mt-4 inline-flex rounded-md border border-neutral-300 bg-white px-4 py-2 text-sm font-semibold text-neutral-800 hover:bg-neutral-100" href={`/s/${tenantSlug}/`}>
            mail.aiboux.com/s/aiboux/
          </a>
        </div>
      </section>
    </main>
  </body>
</html>
