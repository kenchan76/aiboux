---
export const prerender = false;

import FileHomePage from "@/components/file/FileHomePage.astro";
import BizHomePage from "@/components/biz/BizHomePage.astro";
import OfficeHomePage from "@/components/office/OfficeHomePage.astro";
import ResumeHomePage from "@/components/resume/ResumeHomePage.astro";
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";

const host = Astro.request.headers.get("host")?.toLowerCase().split(":")[0] ?? "";
const isFileHost = host === "file.aiboux.com";
const isBizHost = host === "biz.aiboux.com";
const isOfficeHost = host === "office.aiboux.com";
const isResumeHost = host === "rirekisho.aiboux.com";
---

{
  isFileHost ? (
    <FileHomePage canonicalPath="/" />
  ) : isBizHost ? (
    <BizHomePage canonicalPath="/" />
  ) : isOfficeHost ? (
    <OfficeHomePage canonicalPath="/" />
  ) : isResumeHost ? (
    <ResumeHomePage />
  ) : (
    <html lang="ja">
      <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <NotoSansJpHead />
        <title>aiboux</title>
        <meta name="robots" content="noindex" />
      </head>
      <body></body>
    </html>
  )
}
