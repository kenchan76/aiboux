---
interface Props {
  label?: string;
  compact?: boolean;
}

const { label = "広告", compact = false } = Astro.props;
---

<aside class={`rounded-lg border border-dashed border-neutral-300 bg-neutral-50/80 ${compact ? "p-3" : "p-4"}`} aria-label={label}>
  <div class="flex items-start justify-between gap-3">
    <span class="rounded border border-neutral-200 bg-white px-1.5 py-0.5 text-[10px] font-semibold text-neutral-500">{label}</span>
    <span class="text-[11px] text-neutral-500">AdSense / AIBOUX広告枠</span>
  </div>
  <div class="mt-3 grid gap-1">
    <p class="text-sm font-semibold text-neutral-900">広告は編集内容やファイル内容を読み取りません。</p>
    <p class="text-xs leading-5 text-neutral-600">
      保存・ダウンロードなどの操作ボタンと混同しないよう、明示ラベル付きで配置しています。
    </p>
  </div>
</aside>
