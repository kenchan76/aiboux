---
import { supportedFormats } from "@/data/office-content";
import { Card, CardContent } from "@/components/starwind/card";
---

<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-6">
  {supportedFormats.map((format) => (
    <Card size="sm" class="border-neutral-200 bg-white shadow-none">
      <CardContent>
        <p class={`text-lg font-bold ${format.accentClass}`}>{format.extension}</p>
        <h3 class="mt-2 text-sm font-semibold text-neutral-950">{format.title}</h3>
        <p class="mt-1 min-h-12 text-xs leading-5 text-neutral-600">{format.description}</p>
        <p class="mt-3 rounded border border-neutral-200 bg-neutral-50 px-2 py-1 text-[11px] font-semibold text-neutral-700">{format.level}</p>
      </CardContent>
    </Card>
  ))}
</div>
