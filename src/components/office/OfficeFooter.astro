---
import { Badge } from "@/components/starwind/badge";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const productLinks = [
  ["Excel/CSV エディタ", "/office/excel"],
  ["PDF エディタ", "/office/pdf"],
  ["Word クイック編集", "/office/word"],
  ["PowerPoint クイックビュー", "/office/powerpoint"],
];
const supportLinks = [
  ["ヘルプセンター", "/office/help"],
  ["セキュリティ", "/office/security"],
  ["ローカル履歴", "/office/history"],
  ["免責事項", "/office/disclaimer"],
];
const companyLinks = [
  ["プライバシーポリシー", "/office/privacy"],
  ["利用規約", "/office/terms"],
  ["特定商取引法に基づく表記", "/biz/commercial"],
];
---

<footer class="border-t border-neutral-200 bg-white">
  <div class={`mx-auto grid max-w-7xl gap-6 px-4 sm:px-5 lg:grid-cols-[1.1fr_2fr] lg:px-6 ${compact ? "py-6" : "py-9"}`}>
    <div>
      <div class="flex items-center gap-2">
        <span class="text-xl font-semibold tracking-tight text-neutral-950">aiboux</span>
        <Badge variant="outline" size="sm" class="rounded-md border-yellow-300 bg-yellow-300 px-1.5 py-0 text-[10px] font-bold text-neutral-950">OFFICE</Badge>
      </div>
      <p class="mt-3 max-w-md text-sm leading-6 text-neutral-600">
        インストール不要のブラウザ完結Officeツール。開いたファイル本体は原則サーバーへ送信せず、端末内で編集・保存します。
      </p>
      <p class="mt-3 text-[11px] leading-5 text-neutral-500">
        本サービスはMicrosoft Corporation、Google LLC、Adobe Inc.その他各社とは関係ありません。Word、Excel、PowerPoint、Windows、Microsoft Office、Adobe、PDF等は各社の商標または登録商標です。
      </p>
    </div>
    <div class="grid gap-5 sm:grid-cols-3">
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wide text-neutral-500">製品</h2>
        <div class="mt-3 grid gap-2">
          {productLinks.map(([label, href]) => <a href={href} class="text-sm text-neutral-600 hover:text-neutral-950">{label}</a>)}
        </div>
      </div>
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wide text-neutral-500">サポート</h2>
        <div class="mt-3 grid gap-2">
          {supportLinks.map(([label, href]) => <a href={href} class="text-sm text-neutral-600 hover:text-neutral-950">{label}</a>)}
        </div>
      </div>
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-wide text-neutral-500">運営会社</h2>
        <div class="mt-3 grid gap-2">
          {companyLinks.map(([label, href]) => <a href={href} class="text-sm text-neutral-600 hover:text-neutral-950">{label}</a>)}
        </div>
        <p class="mt-4 text-xs text-neutral-500">日本語</p>
      </div>
    </div>
  </div>
</footer>
