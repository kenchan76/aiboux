---
import type { OfficeFeature } from "@/data/office-content";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";

interface Props {
  feature: OfficeFeature;
}

const { feature } = Astro.props;
const accentMap = {
  excel: "border-emerald-200 bg-emerald-50 text-emerald-700",
  pdf: "border-red-200 bg-red-50 text-red-700",
  word: "border-blue-200 bg-blue-50 text-blue-700",
  ppt: "border-orange-200 bg-orange-50 text-orange-700",
  local: "border-violet-200 bg-violet-50 text-violet-700",
  security: "border-sky-200 bg-sky-50 text-sky-700",
};
---

<Card size="sm" class="border-neutral-200 bg-white shadow-none">
  <CardContent>
    <div class="flex h-full flex-col justify-between gap-4">
      <div>
        <span class={`inline-flex rounded-md border px-2 py-1 text-xs font-semibold ${accentMap[feature.accent]}`}>{feature.title.split(" ")[0]}</span>
        <h3 class="mt-3 text-base font-semibold text-neutral-950">{feature.title}</h3>
        <p class="mt-1 text-sm leading-6 text-neutral-600">{feature.description}</p>
      </div>
      <Button href={feature.href} variant="outline" size="sm" class="border-yellow-400 bg-yellow-200 text-neutral-950 hover:bg-yellow-300 hover:text-neutral-950">
        {feature.action}
      </Button>
    </div>
  </CardContent>
</Card>
