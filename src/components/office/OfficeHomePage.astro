---
import AdSenseSlot from "@/components/office/AdSenseSlot.astro";
import FeatureCard from "@/components/office/FeatureCard.astro";
import LocalHistoryPromo from "@/components/office/LocalHistoryPromo.astro";
import OfficeEditorPreview from "@/components/office/OfficeEditorPreview.astro";
import SecurityNotice from "@/components/office/SecurityNotice.astro";
import SupportedFormats from "@/components/office/SupportedFormats.astro";
import OfficeMarketingLayout from "@/layouts/OfficeMarketingLayout.astro";
import { ecosystemCards, mainOfficeFeatures, officeFaqs, officeFeatures } from "@/data/office-content";
import { Accordion, AccordionContent, AccordionItem, AccordionTrigger } from "@/components/starwind/accordion";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";

interface Props {
  canonicalPath?: string;
}

const { canonicalPath = "/office" } = Astro.props;
---

<OfficeMarketingLayout canonicalPath={canonicalPath}>
  <section class="border-b border-neutral-200 bg-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-11 sm:px-5 lg:grid-cols-[0.88fr_1.12fr] lg:px-6 lg:py-12">
      <div class="flex flex-col justify-center gap-5">
        <div class="flex flex-wrap gap-2">
          {["サーバー送信なし", "スマホ対応", "即時編集", "PDF直接編集", "XLSX / CSV", "無料会員登録で履歴化"].map((label) => (
            <Badge variant="outline" size="sm" class="rounded-md border-yellow-300 bg-yellow-50 text-neutral-800">{label}</Badge>
          ))}
        </div>
        <div class="space-y-4">
          <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-neutral-950 sm:text-5xl">
            Officeファイルを、ブラウザだけでサクッと編集。
          </h1>
          <p class="max-w-2xl text-base leading-7 text-neutral-600">
            Word、Excel、PowerPoint、PDF、CSVを、インストール不要で今すぐ編集。ファイルはサーバーに送信されず、すべてブラウザ内で処理されるので安心です。
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <Button href="/office/editor" variant="outline" size="md" class="border-yellow-400 bg-yellow-300 text-neutral-950 hover:bg-yellow-400 hover:text-neutral-950">ファイルを開く</Button>
          <Button href="#features" variant="outline" size="md">機能を見る</Button>
        </div>
        <p class="text-xs leading-5 text-neutral-500">
          Microsoft Office完全互換を謳うサービスではありません。軽微修正、確認、ローカル保存を素早く行うミニマルOfficeツールです。
        </p>
      </div>
      <OfficeEditorPreview />
    </div>
  </section>

  <section class="border-b border-neutral-200 bg-neutral-50/70">
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-5 lg:px-6">
      <AdSenseSlot compact />
    </div>
  </section>

  <section id="features" class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">ブラウザで済ませたい作業だけを、軽く速く。</h2>
          <p class="mt-2 text-sm leading-6 text-neutral-600">重いOffice/PDFライブラリは初期表示に入れず、ファイル選択後に必要な編集機能だけを読み込みます。</p>
        </div>
        <Button href="/office/editor" variant="outline" size="sm" class="hidden border-yellow-400 bg-yellow-300 text-neutral-950 hover:bg-yellow-400 hover:text-neutral-950 sm:inline-flex">今すぐ開く</Button>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {officeFeatures.map((feature) => <FeatureCard feature={feature} />)}
      </div>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-50/70">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <SecurityNotice />
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <div class="mb-5">
        <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">対応ファイル形式</h2>
        <p class="mt-2 text-sm leading-6 text-neutral-600">CSVとXLSXを優先し、PDFは軽微修正、DOCX/PPTXはクイック確認から始めます。</p>
      </div>
      <SupportedFormats />
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-50/70">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <div class="grid gap-5 lg:grid-cols-[1fr_360px]">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">主な機能</h2>
          <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
            {mainOfficeFeatures.map((item) => (
              <Card size="sm" class="border-neutral-200 bg-white shadow-none">
                <CardContent>
                  <p class="text-sm font-semibold text-neutral-950">{item}</p>
                </CardContent>
              </Card>
            ))}
          </div>
        </div>
        <AdSenseSlot />
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <LocalHistoryPromo />
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-50/70">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 py-11 sm:px-5 lg:grid-cols-[0.8fr_1.2fr] lg:px-6">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">AIBOUXエコシステム</h2>
        <p class="mt-2 text-sm leading-6 text-neutral-600">作る、送る、保存する。Aiboux Officeは、周辺サービスとつながる入口として設計しています。</p>
      </div>
      <div class="grid gap-3 md:grid-cols-3">
        {ecosystemCards.map((card) => (
          <Card size="sm" class="border-neutral-200 bg-white shadow-none">
            <CardContent>
              <h3 class="text-sm font-semibold text-neutral-950">{card.name}</h3>
              <p class="mt-1 min-h-16 text-xs leading-5 text-neutral-600">{card.description}</p>
              <a href={card.href} class="mt-3 inline-flex text-xs font-semibold text-neutral-900 hover:underline">詳しく見る</a>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 py-11 sm:px-5 lg:grid-cols-[320px_1fr] lg:px-6">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">よくある質問</h2>
        <p class="mt-2 text-sm leading-6 text-neutral-600">ローカル処理、互換性、広告、保存方法についてまとめています。</p>
      </div>
      <Accordion type="single" collapsible class="rounded-lg border border-neutral-200 bg-white">
        {officeFaqs.map((faq, index) => (
          <AccordionItem value={`faq-${index}`}>
            <AccordionTrigger class="px-4 text-sm font-semibold text-neutral-950">{faq.question}</AccordionTrigger>
            <AccordionContent class="px-4 text-sm leading-6 text-neutral-600">{faq.answer}</AccordionContent>
          </AccordionItem>
        ))}
      </Accordion>
    </div>
  </section>

  <section class="border-y border-neutral-200 bg-neutral-50/70">
    <div class="mx-auto max-w-7xl px-4 py-11 sm:px-5 lg:px-6">
      <div class="rounded-xl border border-neutral-200 bg-white p-6 text-center">
        <h2 class="text-2xl font-semibold tracking-tight text-neutral-950">今すぐ、端末内でファイルを開く。</h2>
        <p class="mx-auto mt-2 max-w-2xl text-sm leading-6 text-neutral-600">
          ファイル本体はサーバーへ送信されません。まずはCSVから、ブラウザだけの編集体験を確認できます。
        </p>
        <div class="mt-5 flex justify-center gap-3">
          <Button href="/office/editor" variant="outline" size="md" class="border-yellow-400 bg-yellow-300 text-neutral-950 hover:bg-yellow-400 hover:text-neutral-950">ファイルを開く</Button>
          <Button href="/office/security" variant="outline" size="md">安全性を見る</Button>
        </div>
      </div>
    </div>
  </section>
</OfficeMarketingLayout>
