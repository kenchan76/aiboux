---
import { Badge } from "@/components/starwind/badge";
---

<div class="overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm">
  <div class="flex items-center justify-between border-b border-neutral-200 bg-neutral-50 px-3 py-2">
    <div class="flex items-center gap-2">
      <span class="text-sm font-semibold text-neutral-950">aiboux</span>
      <Badge variant="outline" size="sm" class="rounded border-yellow-300 bg-yellow-300 text-[10px] font-bold text-neutral-950">OFFICE</Badge>
      <span class="hidden text-xs text-neutral-500 sm:inline">ローカル編集</span>
    </div>
    <div class="flex gap-1">
      <span class="rounded border border-neutral-200 bg-white px-2 py-1 text-[11px] text-neutral-600">保存</span>
      <span class="rounded border border-yellow-400 bg-yellow-300 px-2 py-1 text-[11px] font-semibold text-neutral-950">ダウンロード</span>
    </div>
  </div>
  <div class="grid min-h-[320px] lg:grid-cols-[0.9fr_1fr_190px]">
    <div class="border-b border-neutral-200 lg:border-b-0 lg:border-r">
      <div class="grid grid-cols-5 border-b border-neutral-200 bg-neutral-50 text-[11px] font-semibold text-neutral-500">
        {["A", "B", "C", "D", "E"].map((cell) => <span class="border-r border-neutral-200 px-2 py-1">{cell}</span>)}
      </div>
      {[
        ["商品名", "カテゴリ", "売上", "数量", "単価"],
        ["ノートPC", "PC", "2,340,000", "20", "117,000"],
        ["モニタ", "周辺機器", "461,000", "15", "30,733"],
        ["キーボード", "周辺機器", "168,000", "30", "5,600"],
        ["マウス", "周辺機器", "201,600", "48", "4,200"],
        ["USBメモリ", "記憶媒体", "72,000", "48", "1,500"],
      ].map((row) => (
        <div class="grid grid-cols-5 text-[11px] text-neutral-700">
          {row.map((cell) => <span class="truncate border-b border-r border-neutral-100 px-2 py-1.5">{cell}</span>)}
        </div>
      ))}
    </div>
    <div class="border-b border-neutral-200 p-4 lg:border-b-0 lg:border-r">
      <div class="mx-auto max-w-[360px] rounded border border-neutral-200 bg-white p-5">
        <p class="text-center text-xl font-semibold tracking-[0.2em] text-neutral-950">提案書</p>
        <div class="mt-5 rounded border border-blue-300 bg-blue-50/70 p-3 text-sm leading-6 text-neutral-800">
          aiboux OFFICE は、ブラウザだけでOfficeファイルを安全に軽く編集できるオンラインツールです。
        </div>
        <div class="mt-4 space-y-2 text-xs text-neutral-700">
          {["サーバーに保存されない安心設計", "インストール不要ですぐ使える", "PDFやCSVの軽微修正に対応"].map((item) => (
            <div class="flex gap-2"><span class="text-emerald-600">✓</span><span>{item}</span></div>
          ))}
        </div>
      </div>
    </div>
    <div class="bg-neutral-50 p-3">
      <p class="text-xs font-semibold text-neutral-900">プロパティ</p>
      <div class="mt-3 space-y-2 text-xs text-neutral-600">
        {["フォント", "サイズ", "配置", "色", "余白"].map((label) => (
          <div class="rounded border border-neutral-200 bg-white px-2 py-1.5">
            <span>{label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
  <div class="flex flex-wrap justify-center gap-2 border-t border-neutral-200 bg-neutral-50 px-3 py-2">
    {["CSV", "XLSX", "DOCX", "PPTX", "PDF"].map((format) => (
      <span class="rounded border border-yellow-400 bg-yellow-300 px-3 py-1 text-xs font-semibold text-neutral-950">{format}</span>
    ))}
  </div>
</div>
