---
interface Props {
  title?: string;
  compact?: boolean;
}

const { title = "履歴書", compact = false } = Astro.props;
const rows = compact ? ["氏名", "住所", "学歴", "職歴"] : ["氏名", "生年月日", "住所", "学歴", "職歴", "資格", "志望動機"];
---

<div class="rounded-lg border border-neutral-200 bg-white p-3 shadow-sm">
  <div class="mb-2 flex items-center justify-between text-xs text-neutral-500">
    <span>{title}</span>
    <span>PDF</span>
  </div>
  <div class="aspect-[4/5.6] rounded-md border border-neutral-200 bg-neutral-50 p-3">
    <div class="mx-auto mb-3 h-4 w-24 rounded-sm bg-neutral-900/90"></div>
    <div class="grid grid-cols-[1fr_52px] gap-2">
      <div class="space-y-1.5">
        {rows.map((row) => (
          <div class="grid grid-cols-[54px_1fr] overflow-hidden rounded-sm border border-neutral-200 bg-white text-[10px]">
            <div class="border-r border-neutral-200 bg-neutral-50 px-1.5 py-1 text-neutral-500">{row}</div>
            <div class="px-1.5 py-1 text-neutral-700">{row === "氏名" ? "相棒 太郎" : "入力済み"}</div>
          </div>
        ))}
      </div>
      <div class="h-16 rounded-sm border border-neutral-200 bg-gradient-to-b from-sky-100 to-neutral-100 p-1">
        <div class="mx-auto mt-1 size-6 rounded-full bg-neutral-700"></div>
        <div class="mx-auto mt-1 h-7 w-8 rounded-t-lg bg-blue-900"></div>
      </div>
    </div>
  </div>
</div>

