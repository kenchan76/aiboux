---
import ResumeMarketingLayout from "@/layouts/ResumeMarketingLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { guestBenefits, memberBenefits } from "@/data/resume-content";
---

<ResumeMarketingLayout
  title="AIBOUX 履歴書 | 無料会員登録"
  description="AIBOUX 履歴書の無料会員登録で利用できる保存、再編集、再ダウンロード、求人票解析、AI自己PR、写真作成の機能を紹介します。"
  canonicalPath="/rirekisho/pricing"
>
  <section class="bg-[#F8FAF8]">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-5 lg:px-6">
      <div class="mb-5 text-center">
        <Badge variant="outline" size="sm" class="mb-2 rounded-md border-green-200 bg-green-50 text-green-700">原則フル機能無料</Badge>
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">全機能無料。会員登録で保存・再編集も。</h1>
        <p class="mx-auto mt-2 max-w-2xl text-sm leading-6 text-neutral-600">初期版では有料課金を必須にしません。無料会員登録で応募準備を継続しやすくします。</p>
      </div>
      <div class="grid gap-4 lg:grid-cols-[0.85fr_1.15fr]">
        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <h2 class="text-lg font-semibold text-neutral-950">ゲスト利用</h2>
            <p class="mt-2 text-sm text-neutral-600">登録なしで一部機能を体験できます。</p>
            <ul class="mt-4 space-y-2 text-sm text-neutral-700">
              {guestBenefits.map((item) => <li class="flex gap-2"><span class="text-green-700">✓</span>{item}</li>)}
            </ul>
            <Button href="/rirekisho/resume/new" variant="outline" size="sm" class="mt-5 w-full">ゲストで始める</Button>
          </CardContent>
        </Card>
        <Card size="sm" class="border-green-300 bg-white">
          <CardContent>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <h2 class="text-lg font-semibold text-neutral-950">無料会員登録</h2>
                <p class="mt-2 text-sm text-neutral-600">保存、再編集、求人票解析、写真作成まで無料で利用できます。</p>
              </div>
              <Button href="/rirekisho/dashboard" variant="primary" size="sm">無料で会員登録する</Button>
            </div>
            <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
              {memberBenefits.map((item) => <div class="rounded-md border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800">✓ {item}</div>)}
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>
</ResumeMarketingLayout>

