---
import DocumentPreview from "./DocumentPreview.astro";
import ResumeMarketingLayout from "@/layouts/ResumeMarketingLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { templateCards } from "@/data/resume-content";
---

<ResumeMarketingLayout
  title="AIBOUX 履歴書 | テンプレート一覧"
  description="履歴書、職務経歴書、退職届、送付状、面接チェックリストなどのテンプレートを一覧で確認できます。"
  canonicalPath="/rirekisho/templates"
>
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-5 lg:px-6">
      <div class="mb-5">
        <Badge variant="outline" size="sm" class="mb-2 rounded-md border-green-200 bg-green-50 text-green-700">無料テンプレート</Badge>
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">テンプレート一覧</h1>
        <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600">応募書類、退職書類、準備チェックリストをスマホで使いやすい形に整理しています。</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        {templateCards.map((template) => (
          <Card size="sm" class="border-neutral-200 bg-white">
            <CardContent>
              <DocumentPreview title={template.title} compact />
              <h2 class="mt-3 text-sm font-semibold text-neutral-950">{template.title}</h2>
              <p class="mt-2 text-sm leading-6 text-neutral-600">{template.description}</p>
              <Button href={template.href} variant="outline" size="sm" class="mt-3 w-full border-green-200 text-green-700 hover:bg-green-50">使う</Button>
            </CardContent>
          </Card>
        ))}
      </div>
    </div>
  </section>
</ResumeMarketingLayout>

