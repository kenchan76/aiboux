---
import AdSlot from "@/components/file/AdSlot.astro";
import TransferTabs from "@/components/file/TransferTabs.astro";
import { Card, CardContent } from "@/components/starwind/card";
import { Progress } from "@/components/starwind/progress";
---

<div class="mx-auto grid max-w-6xl gap-4 px-4 py-8 sm:px-5 lg:grid-cols-[1fr_320px] lg:px-6">
  <div class="space-y-4">
    <TransferTabs compact />
    <Card size="sm" class="border-neutral-200">
      <CardContent class="space-y-3">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-base font-semibold text-neutral-950">送信準備の確認</h2>
            <p class="text-sm text-neutral-600">ファイル、宛先、期限、パスワードを同じ画面で確認できます。</p>
          </div>
          <span class="text-xs font-medium text-neutral-500">Demo flow</span>
        </div>
        <Progress value={62} variant="primary" aria-label="送信準備の進行状況" />
        <div class="grid gap-2 text-sm sm:grid-cols-3">
          <div class="rounded-md border border-neutral-200 bg-neutral-50 p-3">
            <div class="text-xs text-neutral-500">選択ファイル</div>
            <div class="mt-1 font-semibold text-neutral-950">未選択</div>
          </div>
          <div class="rounded-md border border-neutral-200 bg-neutral-50 p-3">
            <div class="text-xs text-neutral-500">保存期間</div>
            <div class="mt-1 font-semibold text-neutral-950">7日</div>
          </div>
          <div class="rounded-md border border-neutral-200 bg-neutral-50 p-3">
            <div class="text-xs text-neutral-500">保護</div>
            <div class="mt-1 font-semibold text-neutral-950">任意パスワード</div>
          </div>
        </div>
      </CardContent>
    </Card>
  </div>
  <aside class="space-y-4">
    <AdSlot />
    <Card size="sm" class="border-blue-200 bg-blue-50/30">
      <CardContent class="space-y-2">
        <h2 class="text-sm font-semibold text-neutral-950">Plus Liteで履歴を残す</h2>
        <p class="text-sm leading-6 text-neutral-600">送信履歴、再ダウンロード、再共有、期限変更を月500円で利用できます。</p>
      </CardContent>
    </Card>
  </aside>
</div>
