---
import type { BizTemplate } from "@/data/biz-content";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";

interface Props {
  template: BizTemplate;
}
const { template } = Astro.props;
---

<Card size="sm" class="h-full border-neutral-200 bg-white">
  <CardContent class="grid h-full grid-cols-[72px_1fr] gap-3">
    <a href={`/biz/templates/${template.slug}`} class="rounded-md border border-neutral-200 bg-neutral-50 p-2">
      <div class="h-24 rounded border border-neutral-200 bg-white p-2 text-[8px] leading-3 text-neutral-500">
        <div class="mb-2 h-2 w-14 bg-neutral-200"></div>
        <div class="mb-1 h-1.5 w-full bg-neutral-100"></div>
        <div class="mb-1 h-1.5 w-10/12 bg-neutral-100"></div>
        <div class="mt-4 grid grid-cols-3 gap-1">
          <span class="h-5 bg-neutral-100"></span><span class="h-5 bg-neutral-100"></span><span class="h-5 bg-neutral-100"></span>
        </div>
      </div>
    </a>
    <div class="flex min-w-0 flex-col">
      <div class="flex items-start justify-between gap-2">
        <h3 class="line-clamp-2 text-sm font-semibold text-neutral-950">{template.title}</h3>
        <Badge variant="outline" size="sm" class={template.isFree ? "border-violet-200 bg-violet-50 text-violet-700" : "border-neutral-200 bg-neutral-50 text-neutral-600"}>
          {template.isFree ? "無料" : "Plus"}
        </Badge>
      </div>
      <p class="mt-1 line-clamp-2 text-sm leading-5 text-neutral-600">{template.description}</p>
      <div class="mt-2 flex flex-wrap gap-1">
        {template.formats.slice(0, 3).map((format) => <Badge variant="outline" size="sm" class="border-neutral-200 bg-neutral-50 text-[10px] text-neutral-600">{format}</Badge>)}
      </div>
      <div class="mt-auto flex gap-2 pt-3">
        <Button href="/biz/editor" variant="outline" size="sm" class="border-violet-200 text-violet-700 hover:bg-violet-50">編集する</Button>
        <Button href={`/biz/templates/${template.slug}`} variant="outline" size="sm">詳細</Button>
      </div>
    </div>
  </CardContent>
</Card>
