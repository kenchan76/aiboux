---
const serviceLinks = [
  { label: "テンプレート一覧", href: "/biz/templates" },
  { label: "テンプレートを作成", href: "/biz/editor" },
  { label: "Webエディタ", href: "/biz/editor" },
  { label: "料金プラン", href: "/biz/pricing" },
];
const supportLinks = [
  { label: "ヘルプセンター", href: "/biz/help" },
  { label: "よくあるご質問", href: "/biz/help#faq" },
  { label: "利用規約", href: "/biz/terms" },
  { label: "プライバシーポリシー", href: "/biz/privacy" },
];
---

<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-8 sm:px-5 md:grid-cols-[1.4fr_1fr_1fr_1fr] lg:px-6">
    <div class="space-y-3">
      <div class="flex items-center gap-2">
        <span class="text-xl font-semibold tracking-tight text-neutral-950">aiboux</span>
        <span class="rounded-md border border-violet-200 bg-violet-50 px-1.5 py-0.5 text-[10px] font-semibold text-violet-700">BIZ</span>
      </div>
      <p class="max-w-sm text-sm leading-6 text-neutral-600">
        ビジネス文書とテンプレートの作成、編集、管理をひとつにまとめる文書サービスです。
      </p>
      <p class="text-xs text-neutral-500">© 2026 aiboux Inc. All rights reserved.</p>
    </div>
    <div>
      <h2 class="text-sm font-semibold text-neutral-950">サービス</h2>
      <ul class="mt-2 space-y-1.5 text-sm text-neutral-600">
        {serviceLinks.map((item) => <li><a class="hover:text-neutral-950" href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h2 class="text-sm font-semibold text-neutral-950">サポート</h2>
      <ul class="mt-2 space-y-1.5 text-sm text-neutral-600">
        {supportLinks.map((item) => <li><a class="hover:text-neutral-950" href={item.href}>{item.label}</a></li>)}
      </ul>
    </div>
    <div>
      <h2 class="text-sm font-semibold text-neutral-950">会社情報</h2>
      <ul class="mt-2 space-y-1.5 text-sm text-neutral-600">
        <li><a class="hover:text-neutral-950" href="/biz/commercial">特定商取引法に基づく表記</a></li>
        <li><a class="hover:text-neutral-950" href="/biz/help">お問い合わせ</a></li>
        <li><span>X / Facebook / YouTube</span></li>
      </ul>
      <div class="mt-4 text-xs text-neutral-500">言語: 日本語</div>
    </div>
  </div>
</footer>
