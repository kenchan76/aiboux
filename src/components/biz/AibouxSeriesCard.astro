---
import { Badge } from "@/components/starwind/badge";
---

<div class="rounded-lg border border-neutral-200 bg-white p-4">
  <div class="mb-3 text-xs font-semibold text-neutral-950">aiboux シリーズ連携</div>
  <div class="grid grid-cols-2 gap-2 text-sm sm:grid-cols-4">
    {[
      ["FILE", "ファイル共有", "text-blue-700", "bg-blue-50", "border-blue-200"],
      ["MAIL", "メール送信", "text-sky-700", "bg-sky-50", "border-sky-200"],
      ["SHOP", "店舗運営", "text-emerald-700", "bg-emerald-50", "border-emerald-200"],
      ["CORE", "帳票連携", "text-violet-700", "bg-violet-50", "border-violet-200"],
    ].map(([name, text, color, bg, border]) => (
      <div class="flex items-center justify-between rounded-md border border-neutral-200 px-2.5 py-2">
        <span class="font-semibold text-neutral-950">aiboux</span>
        <Badge variant="outline" class={`${border} ${bg} ${color} text-[10px]`}>{name}</Badge>
      </div>
    ))}
  </div>
</div>
