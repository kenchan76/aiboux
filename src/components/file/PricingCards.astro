---
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/starwind/card";
import type { FilePricingPlan } from "@/data/pricing";

interface Props {
  plans: FilePricingPlan[];
}

const { plans } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2">
  {plans.map((plan) => (
    <Card size="sm" class={`border-neutral-200 ${plan.highlighted ? "border-blue-300 bg-blue-50/20" : ""}`}>
      <CardHeader>
        <div class="flex items-start justify-between gap-3">
          <div>
            <CardTitle class="text-lg">{plan.name}</CardTitle>
            <p class="mt-1 text-sm text-neutral-600">{plan.description}</p>
          </div>
          {plan.highlighted && <Badge variant="primary" size="sm" class="rounded-md">おすすめ</Badge>}
        </div>
      </CardHeader>
      <CardContent class="space-y-4">
        <div class="flex items-end gap-1">
          <span class="text-3xl font-semibold tracking-tight text-neutral-950">{plan.price}</span>
          {plan.highlighted && <span class="pb-1 text-xs text-neutral-500">税込</span>}
        </div>
        <div class="grid gap-2 text-sm">
          {plan.features.map((feature) => (
            <div class="flex gap-2 text-neutral-700"><span class="text-emerald-600">✓</span><span>{feature}</span></div>
          ))}
          {plan.limitations?.map((item) => (
            <div class="flex gap-2 text-neutral-500"><span>・</span><span>{item}</span></div>
          ))}
        </div>
        <Button href={plan.highlighted ? "/file/pricing" : "/file/transfer"} variant={plan.highlighted ? "primary" : "outline"} size="sm" class="w-full">
          {plan.cta}
        </Button>
      </CardContent>
    </Card>
  ))}
</div>
