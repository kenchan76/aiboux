---
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import type { FileTool } from "@/data/file-tools";

interface Props {
  tool: FileTool;
}

const { tool } = Astro.props;
---

<Card size="sm" class="h-full border-neutral-200 transition hover:border-blue-200 hover:bg-neutral-50/80">
  <CardContent class="flex h-full flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
      <div class="flex size-9 items-center justify-center rounded-md border border-neutral-200 bg-white text-xs font-semibold text-blue-700">
        {tool.category.toUpperCase().slice(0, 2)}
      </div>
      {tool.badge && <Badge variant="outline" size="sm" class="rounded-md border-blue-200 bg-blue-50 text-blue-700">{tool.badge}</Badge>}
    </div>
    <div class="space-y-1">
      <h3 class="text-base font-semibold text-neutral-950">{tool.title}</h3>
      <p class="text-sm leading-6 text-neutral-600">{tool.description}</p>
    </div>
    <div class="mt-auto">
      <Button href={tool.href} variant="outline" size="sm" class="w-full justify-between">
        使う
        <span aria-hidden="true">-&gt;</span>
      </Button>
    </div>
  </CardContent>
</Card>
