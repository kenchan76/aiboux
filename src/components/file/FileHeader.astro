---
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import {
  Sheet,
  SheetContent,
  SheetDescription,
  SheetHeader,
  SheetTitle,
  SheetTrigger,
} from "@/components/starwind/sheet";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const navItems = [
  { label: "機能", href: "/file/#features" },
  { label: "ツール", href: "/file/tools" },
  { label: "料金", href: "/file/pricing" },
  { label: "活用例", href: "/file/#usecases" },
  { label: "ヘルプ", href: "/file/help" },
];
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 backdrop-blur-sm">
  <div class={`mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 sm:px-5 lg:px-6 ${compact ? "h-12" : "h-14"}`}>
    <a href="/file" class="flex items-center gap-2 text-neutral-950" aria-label="AIBOUX FILE トップへ">
      <span class="text-xl font-semibold tracking-tight">aiboux</span>
      <Badge variant="outline" size="sm" class="rounded-md border-blue-200 bg-blue-50 px-1.5 py-0 text-[10px] font-semibold text-blue-700">FILE</Badge>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="主要メニュー">
      {navItems.map((item) => (
        <a href={item.href} class="rounded-md px-2.5 py-1.5 text-sm font-medium text-neutral-600 transition hover:bg-neutral-100 hover:text-neutral-950">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <Button href="/file/dashboard" variant="outline" size="sm">ログイン</Button>
      <Button href="/file/transfer" variant="primary" size="sm">無料で使う</Button>
    </div>

    <div class="md:hidden">
      <Sheet>
        <SheetTrigger>
          <Button variant="outline" size="sm" aria-label="メニューを開く">
            <span class="block h-0.5 w-4 bg-neutral-800"></span>
            <span class="block h-0.5 w-4 bg-neutral-800"></span>
            <span class="block h-0.5 w-4 bg-neutral-800"></span>
          </Button>
        </SheetTrigger>
        <SheetContent side="right" class="w-[88vw] max-w-xs bg-white">
          <SheetHeader>
            <SheetTitle>aiboux FILE</SheetTitle>
            <SheetDescription>ファイル転送、PDF、画像、バーコードの作業メニューです。</SheetDescription>
          </SheetHeader>
          <div class="mt-5 grid gap-1">
            {navItems.map((item) => (
              <a href={item.href} class="rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-100">
                {item.label}
              </a>
            ))}
          </div>
          <div class="mt-5 grid grid-cols-2 gap-2">
            <Button href="/file/dashboard" variant="outline" size="sm">ログイン</Button>
            <Button href="/file/transfer" variant="primary" size="sm">無料で使う</Button>
          </div>
        </SheetContent>
      </Sheet>
    </div>
  </div>
</header>
