---
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import type { FileUseCase } from "@/data/file-tools";

interface Props {
  item: FileUseCase;
}

const { item } = Astro.props;
---

<Card size="sm" class="border-neutral-200 bg-white">
  <CardContent class="space-y-3">
    <div class="flex items-center justify-between gap-3">
      <div class="flex size-10 items-center justify-center rounded-lg border border-neutral-200 bg-neutral-50 text-xs font-semibold text-neutral-700">
        {item.metric.slice(0, 2)}
      </div>
      <Badge variant="outline" size="sm" class="rounded-md text-neutral-600">{item.metric}</Badge>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-neutral-950">{item.title}</h3>
      <p class="mt-1 text-sm leading-6 text-neutral-600">{item.description}</p>
    </div>
  </CardContent>
</Card>
