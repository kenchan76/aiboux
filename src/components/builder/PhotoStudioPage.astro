---
import ResumeEditorLayout from "@/layouts/ResumeEditorLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { NativeSelect, NativeSelectOption } from "@/components/starwind/native-select";
import { photoSteps } from "@/data/resume-content";
---

<ResumeEditorLayout
  title="AIBOUX 履歴書 | 証明写真作成"
  description="スマホ写真を履歴書用に整え、顔切り抜き、背景調整、スーツ合成、ネットプリント用PDFを作成します。"
  canonicalPath="/rirekisho/photo"
>
  <section class="bg-[#F8FAF8]">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 py-8 sm:px-5 lg:grid-cols-[0.9fr_1.1fr] lg:px-6">
      <div class="space-y-4">
        <Badge variant="outline" size="sm" class="rounded-md border-green-200 bg-green-50 text-green-700">スマホ写真対応</Badge>
        <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">証明写真作成</h1>
        <p class="text-sm leading-6 text-neutral-600">顔位置ガイド、背景調整、スーツ合成、ネットプリント向けPDFまで、応募写真を整えます。</p>
        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <div class="rounded-lg border border-dashed border-green-300 bg-green-50/60 p-6 text-center">
              <div class="mx-auto flex size-12 items-center justify-center rounded-md border border-green-200 bg-white text-lg font-semibold text-green-700">写</div>
              <h2 class="mt-3 text-sm font-semibold text-neutral-950">写真をアップロード</h2>
              <p class="mt-1 text-sm leading-6 text-neutral-600">スマホではカメラ撮影または写真ライブラリから選択できます。</p>
              <Button variant="primary" size="sm" class="mt-4" data-resume-toast data-toast-title="写真を読み込みました">写真を選択</Button>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              <label class="grid gap-1.5 text-sm font-medium text-neutral-700">背景色<NativeSelect size="sm"><NativeSelectOption value="white">白</NativeSelectOption><NativeSelectOption value="blue">薄い青</NativeSelectOption><NativeSelectOption value="gray">薄いグレー</NativeSelectOption></NativeSelect></label>
              <label class="grid gap-1.5 text-sm font-medium text-neutral-700">出力形式<NativeSelect size="sm"><NativeSelectOption value="png">透明PNG</NativeSelectOption><NativeSelectOption value="jpg">白背景JPG</NativeSelectOption><NativeSelectOption value="pdf">ネットプリントPDF</NativeSelectOption></NativeSelect></label>
            </div>
          </CardContent>
        </Card>
      </div>
      <Card size="sm" class="border-neutral-200 bg-white">
        <CardContent>
          <h2 class="text-sm font-semibold text-neutral-950">Before / After</h2>
          <div class="mt-4 grid grid-cols-[1fr_auto_1fr] items-center gap-3">
            {["補正前", "補正後（スーツ合成）"].map((label, index) => (
              <div class={`rounded-lg border p-3 ${index === 0 ? "border-neutral-200 bg-neutral-50" : "border-green-200 bg-green-50"}`}>
                <div class="aspect-[3/4] rounded-md bg-gradient-to-b from-sky-100 to-white">
                  <div class="mx-auto pt-8">
                    <div class="mx-auto size-14 rounded-full bg-neutral-800"></div>
                    <div class={`mx-auto mt-3 h-20 w-24 rounded-t-2xl ${index === 0 ? "bg-neutral-500" : "bg-blue-950"}`}></div>
                  </div>
                </div>
                <p class="mt-2 text-center text-xs text-neutral-600">{label}</p>
              </div>
            ))}
            <span class="-order-none text-green-700">→</span>
          </div>
          <div class="mt-4 grid gap-2 sm:grid-cols-2">
            {photoSteps.map((step) => <div class="rounded-md border border-green-200 bg-green-50 px-3 py-2 text-sm text-green-800">✓ {step}</div>)}
          </div>
          <Button href="/rirekisho/photo/print" variant="primary" size="sm" class="mt-4 w-full">ネットプリント用PDFを作る</Button>
        </CardContent>
      </Card>
    </div>
  </section>
</ResumeEditorLayout>

