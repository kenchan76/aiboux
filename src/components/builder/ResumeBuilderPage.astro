---
import DocumentPreview from "@/components/resume/DocumentPreview.astro";
import ResumeEditorLayout from "@/layouts/ResumeEditorLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { Input } from "@/components/starwind/input";
import { Textarea } from "@/components/starwind/textarea";
import { NativeSelect, NativeSelectOption } from "@/components/starwind/native-select";
import { Progress } from "@/components/starwind/progress";
import { builderPages } from "@/data/resume-content";

type BuilderKey = keyof typeof builderPages;

interface Props {
  pageKey: BuilderKey;
  canonicalPath: string;
}

const { pageKey, canonicalPath } = Astro.props;
const page = builderPages[pageKey];
const title = `AIBOUX 履歴書 | ${page.title}`;
const description = page.description;
---

<ResumeEditorLayout title={title} description={description} canonicalPath={canonicalPath}>
  <section class="border-b border-neutral-200 bg-[#F8FAF8]">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-5 lg:px-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <div class="mb-2 flex flex-wrap gap-2">
            <Badge variant="outline" size="sm" class="rounded-md border-green-200 bg-green-50 text-green-700">スマホ入力</Badge>
            <Badge variant="outline" size="sm" class="rounded-md border-neutral-200 bg-white text-neutral-600">保存は無料会員</Badge>
          </div>
          <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">{page.title}</h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600">{page.description}</p>
        </div>
        <div class="flex gap-2">
          <Button variant="outline" size="sm" data-resume-toast data-toast-title="プレビューを更新しました">プレビュー</Button>
          <Button variant="primary" size="sm" data-resume-toast data-toast-title="保存確認" data-toast-description="無料会員登録後に保存・再編集・再ダウンロードが利用できます。">{page.saveLabel}</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 py-8 sm:px-5 lg:grid-cols-[1fr_340px] lg:px-6">
      <div class="space-y-4">
        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <div class="mb-4 flex items-center justify-between gap-3">
              <div>
                <h2 class="text-sm font-semibold text-neutral-950">入力ステップ</h2>
                <p class="mt-1 text-xs text-neutral-500">スマホでは上から順番に入力できます。</p>
              </div>
              <div class="w-32"><Progress value={38} /></div>
            </div>
            <div class="flex gap-2 overflow-x-auto pb-1">
              {page.steps.map((step, index) => (
                <Badge variant="outline" size="sm" class={`shrink-0 rounded-md ${index === 0 ? "border-green-200 bg-green-50 text-green-700" : "border-neutral-200 bg-neutral-50 text-neutral-600"}`}>
                  {index + 1}. {step}
                </Badge>
              ))}
            </div>
          </CardContent>
        </Card>

        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <h2 class="text-sm font-semibold text-neutral-950">基本入力</h2>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
              {page.fields.map((field, index) => (
                <label class="grid gap-1.5 text-sm font-medium text-neutral-700">
                  {field}
                  {index === 2 ? (
                    <NativeSelect size="sm" aria-label={field}>
                      <NativeSelectOption value="sample">選択してください</NativeSelectOption>
                      <NativeSelectOption value="one">入力候補 1</NativeSelectOption>
                      <NativeSelectOption value="two">入力候補 2</NativeSelectOption>
                    </NativeSelect>
                  ) : index === page.fields.length - 1 ? (
                    <Textarea placeholder={`${field}を入力`} class="min-h-24 text-sm" />
                  ) : (
                    <Input placeholder={`${field}を入力`} class="h-9 text-sm" />
                  )}
                </label>
              ))}
            </div>
          </CardContent>
        </Card>

        <div class="sticky bottom-0 -mx-4 border-t border-neutral-200 bg-white/95 px-4 py-3 backdrop-blur sm:hidden">
          <Button variant="primary" size="md" class="w-full" data-resume-toast data-toast-title="入力内容を保存しました">{page.saveLabel}</Button>
        </div>
      </div>
      <aside class="space-y-4">
        <DocumentPreview title={page.previewTitle} />
        <Card size="sm" class="border-neutral-200 bg-[#F8FAF8]">
          <CardContent>
            <h2 class="text-sm font-semibold text-neutral-950">無料会員でできること</h2>
            <ul class="mt-3 space-y-2 text-sm text-neutral-700">
              {["保存", "再編集", "再ダウンロード", "スマホ・PCで継続編集"].map((item) => (
                <li class="flex gap-2"><span class="text-green-700">✓</span>{item}</li>
              ))}
            </ul>
            <Button href="/rirekisho/pricing" variant="outline" size="sm" class="mt-4 w-full">無料会員登録のメリット</Button>
          </CardContent>
        </Card>
      </aside>
    </div>
  </section>
</ResumeEditorLayout>

