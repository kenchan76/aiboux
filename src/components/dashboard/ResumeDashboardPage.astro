---
import ResumeEditorLayout from "@/layouts/ResumeEditorLayout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/starwind/table";
import { savedItems } from "@/data/resume-content";
---

<ResumeEditorLayout
  title="AIBOUX 履歴書 | 保存データ一覧"
  description="無料会員向けに、履歴書、職務経歴書、退職届、送付状、写真、求人解析結果を保存・再編集する画面です。"
  canonicalPath="/rirekisho/dashboard"
>
  <section class="bg-[#F8FAF8]">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-5 lg:px-6">
      <div class="mb-5 flex flex-wrap items-start justify-between gap-4">
        <div>
          <Badge variant="outline" size="sm" class="mb-2 rounded-md border-green-200 bg-green-50 text-green-700">無料会員</Badge>
          <h1 class="text-3xl font-semibold tracking-tight text-neutral-950">保存データ一覧</h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-600">作成した履歴書、職務経歴書、写真、求人解析結果をまとめて確認できます。</p>
        </div>
        <Button href="/rirekisho/resume/new" variant="primary" size="sm">新しく作成</Button>
      </div>
      <div class="grid gap-4 lg:grid-cols-[220px_1fr]">
        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <nav class="grid gap-1 text-sm">
              {["すべて", "履歴書", "職務経歴書", "退職届", "送付状", "写真", "求人解析結果"].map((item, index) => (
                <a href="#" class={`rounded-md px-3 py-2 ${index === 0 ? "bg-green-50 text-green-800" : "text-neutral-700 hover:bg-neutral-100"}`}>{item}</a>
              ))}
            </nav>
          </CardContent>
        </Card>
        <Card size="sm" class="border-neutral-200 bg-white">
          <CardContent>
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>名前</TableHead>
                  <TableHead>種類</TableHead>
                  <TableHead>更新日</TableHead>
                  <TableHead>状態</TableHead>
                  <TableHead>操作</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {savedItems.map((item) => (
                  <TableRow>
                    <TableCell class="font-medium">{item.name}</TableCell>
                    <TableCell>{item.type}</TableCell>
                    <TableCell>{item.updated}</TableCell>
                    <TableCell><Badge variant="outline" size="sm" class="rounded-md border-green-200 bg-green-50 text-green-700">{item.status}</Badge></TableCell>
                    <TableCell>
                      <div class="flex gap-2">
                        <Button variant="outline" size="sm">編集</Button>
                        <Button variant="outline" size="sm">再DL</Button>
                      </div>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>
</ResumeEditorLayout>

