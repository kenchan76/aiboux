---
import { GlobalAIAssistant } from "@/components/ai/GlobalAIAssistant";
import "../styles/starwind.css";
import BizFooter from "@/components/biz/BizFooter.astro";
import BizHeader from "@/components/biz/BizHeader.astro";
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";
import { Toaster } from "@/components/starwind/toast";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  title = "AIBOUX BIZ | ビジネス文書・テンプレート作成・編集・管理",
  description = "AIBOUX BIZは、契約書、請求書、見積書、報告書、企画書、提案書などのビジネステンプレートを探して、Webエディタで編集し、そのままダウンロードできるビジネス文書サービスです。",
  canonicalPath = Astro.url.pathname,
  noindex = false,
} = Astro.props;

const canonical = new URL(canonicalPath, "https://biz.aiboux.com").toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <NotoSansJpHead />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://biz.aiboux.com/og-biz.png" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body class="min-h-screen bg-white text-neutral-950 antialiased">
    <BizHeader />
    <main>
      <slot />
    </main>
    <BizFooter />
    <Toaster position="bottom-right" />
    <script>
      const setupBizDemoToasts = () => {
        document.querySelectorAll<HTMLElement>("[data-biz-toast]").forEach((button) => {
          if (button.dataset.toastBound === "true") return;
          button.dataset.toastBound = "true";
          button.addEventListener("click", () => {
            const manager = (window as any).__starwind__?.toast;
            manager?.add({
              title: button.dataset.toastTitle || "デモ",
              description: button.dataset.toastDescription || "正式版で実行されます。",
              variant: "info",
              duration: 3600,
            });
          });
        });
      };

      setupBizDemoToasts();
      document.addEventListener("astro:after-swap", setupBizDemoToasts);
    </script>
      <GlobalAIAssistant client:load service="Biz" />
  </body>
</html>
