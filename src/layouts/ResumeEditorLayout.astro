---
import { GlobalAIAssistant } from "@/components/ai/GlobalAIAssistant";
import ResumeMarketingLayout from "./ResumeMarketingLayout.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;
---

<ResumeMarketingLayout title={title} description={description} canonicalPath={canonicalPath} robots="noindex,nofollow">
  <slot />
</ResumeMarketingLayout>

