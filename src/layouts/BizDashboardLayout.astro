---
import { GlobalAIAssistant } from "@/components/ai/GlobalAIAssistant";
import "../styles/starwind.css";
import BizHeader from "@/components/biz/BizHeader.astro";
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";
import { Toaster } from "@/components/starwind/toast";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = "AIBOUX BIZ Dashboard",
  description = "AIBOUX BIZ Plus Lite向けの文書履歴ダッシュボードです。",
  canonicalPath = Astro.url.pathname,
} = Astro.props;
const canonical = new URL(canonicalPath, "https://biz.aiboux.com").toString();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <NotoSansJpHead />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-neutral-50 text-neutral-950 antialiased">
    <BizHeader compact />
    <slot />
    <Toaster position="bottom-right" />
      <GlobalAIAssistant client:load service="Biz" />
  </body>
</html>
