---
import { GlobalAIAssistant } from "@/components/ai/GlobalAIAssistant";
import NotoSansJpHead from "@/components/common/NotoSansJpHead.astro";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "aiboux Core" } = Astro.props;
---

<!doctype html>
<html lang="ja" class="bg-white">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <NotoSansJpHead />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-neutral-900 antialiased">
    <slot />
      <GlobalAIAssistant client:load service="Core" defaultOpen={false} />
  </body>
</html>
