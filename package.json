{
  "name": "aiboux",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "npm run check:shop-ui-protection && astro build && wrangler deploy",
    "deploy:preview": "npm run check:shop-ui-protection && astro build && node scripts/prepare-preview-wrangler-config.mjs && wrangler deploy --config dist/server/wrangler.preview.json --keep-vars",
    "deploy:prod": "npm run check:shop-ui-protection && astro build && wrangler deploy --keep-vars",
    "shop:checkpoint": "node scripts/create-shop-wip-checkpoint.mjs --commit",
    "deploy:shop:wip": "npm run shop:checkpoint && npm run check:control-chars && npm run check:mojibake && npm run astro check && ESBUILD_WORKER_THREADS=0 npm run build && npm run check:shop-ui-protection && npx wrangler deploy",
    "verify:shop:final": "npm run check:control-chars && npm run check:mojibake && npm run gate:aiboux && npm run check:shop-ui-protection:strict && ESBUILD_WORKER_THREADS=0 npm run build && npx playwright test",
    "notify:bark": "node scripts/notify-bark.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:control-chars": "node scripts/check-control-chars.mjs",
    "check:bark-policy": "node scripts/check-bark-policy.mjs",
    "check:report-policy": "node scripts/check-report-policy.mjs",
    "check:shop-ui-protection": "node scripts/check-shop-ui-protection.mjs --mode=warn",
    "check:shop-ui-protection:strict": "node scripts/check-shop-ui-protection.mjs --mode=strict",
    "gate:aiboux": "node scripts/aiboux-gate-check.mjs --stage all",
    "gate:code": "node scripts/aiboux-gate-check.mjs --stage code",
    "gate:preview": "node scripts/aiboux-gate-check.mjs --stage preview",
    "gate:design": "node scripts/aiboux-design-gate.mjs",
    "gate:design:legacy": "node scripts/aiboux-design-gate.mjs",
    "gate:shop-design": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-design-editor-public.spec.ts",
    "gate:shop-storefront-visual": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-storefront-visual-public.spec.ts",
    "gate:shop-storefront-carousel": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-storefront-carousel-public.spec.ts",
    "gate:shop-storefront-interaction": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-storefront-interaction-public.spec.ts",
    "gate:shop-subscriptions": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-subscriptions-public.spec.ts",
    "gate:shop-public-crawl": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-public-crawl.spec.ts",
    "gate:shop-seo-structure": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-public-crawl.spec.ts --grep \"public storefront pages render|shared category links|robots and sitemap|stable category product URLs|storefront search\"",
    "gate:shop-product-detail": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-product-detail-public.spec.ts",
    "gate:shop-cart-checkout": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-cart-checkout-public.spec.ts",
    "gate:shop-contact-legal": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-contact-legal-public.spec.ts",
    "gate:shop-admin-ops": "PLAYWRIGHT_BASE_URL=https://shop.aiboux.com playwright test tests/shop-admin-ops-public.spec.ts",
    "gate:shop-sales-quality": "npm run gate:shop-public-crawl && npm run gate:shop-storefront-carousel && npm run gate:shop-storefront-interaction && npm run gate:shop-storefront-visual && npm run gate:shop-product-detail && npm run gate:shop-cart-checkout && npm run gate:shop-contact-legal && npm run gate:shop-admin-ops",
    "gate:deploy": "node scripts/aiboux-gate-check.mjs --stage deploy",
    "gate:final": "node scripts/aiboux-gate-check.mjs --stage final",
    "cf:types": "wrangler types",
    "db:apply:local": "wrangler d1 execute aiboux-mail-db --local --file=schema.sql",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tabler/icons": "^3.44.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.5.4",
    "@cloudflare/workers-types": "^4.20260523.1",
    "@playwright/test": "^1.60.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  }
}
