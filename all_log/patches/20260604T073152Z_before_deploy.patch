+  const load = React.useCallback(() => {
+    setLoading(true);
+    fetch("/shop/api/subscriptions")
+      .then(async (response) => {
+        const data = (await response.json().catch(() => ({}))) as { success?: boolean; error?: string; subscriptions?: Array<Record<string, unknown>> };
